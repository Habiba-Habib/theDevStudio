<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Profile</title>
    <link rel="stylesheet" href="/css/profiles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
   
    
</head>

<body>
  <%- include('../partials/navbar') %>
  
    <h1 class="page-title">My Profile</h1>

  <main class="profile-container">

    <aside class="sidebar">
      <div class="avatar">
        <img src="/images/avatars/<%= user.avatar || 'avatar1g.png' %>">
      </div>
      <h2><%= user.name %></h2>
      <p class="email"><%= user.email %></p>

      <% if (user.role === "student") { %>
        <div class="stat-card">
          <h3><%= user.points || 0 %></h3>
          <p>Total Points</p>
        </div>

        <div class="stat-card">
          <h3 style="color:#61b2b1">#<%= typeof rank !== "undefined" ? rank : "N/A" %></h3>
          <p>Global Rank</p>
        </div>

        <div class="stat-card">
          <h3 style="color:#ffb6e6"><%= user.badges?.length || 0 %></h3>
          <p>Badges Earned</p>
        </div>
      <% } %>
      <a href="/<%= user.role %>/edit-profile" class="edit-btn" id="editProfileBtn">
        Edit Profile
      </a>
    </aside>
    <div class="right-content">
    <section class="content">
      <h1>Personal Information</h1>

      <div class="profile-info">
        <div class="profile-grid">

          <div class="profile-group">
            <label>Full Name</label>
            <input type="text" id="name" value="<%= user.name %>" readonly>
          </div>

          <div class="profile-group">
            <label>Email</label>
            <input type="email" id="email" value="<%= user.email %>" readonly>
          </div>

          <div class="profile-group bio">
            <label>Bio</label>
            <textarea id="bio" readonly><%= user.bio %></textarea>
          </div>

          <div class="profile-group">
            <label>Location</label>
            <input type="text" id="location" value="<%= user.location %>" readonly>
          </div>

          <div class="profile-group">
                <label>Member Since</label>
                <input
                  type="text"
                  value="<%= user.createdAt ? user.createdAt.toLocaleDateString() : 'N/A' %>"
                  id="membersince"
                  name="member_since"
                  readonly
                >
           
          </div>

        </div>

        
    </div>
    </section>
    <% if (user.role === "student") { %>
  <section class="completed-courses">
    <h2 class="section-title">
      <i class="fa-solid fa-trophy"></i>
      Completed Courses
    </h2>

    <% if (completedCourses && completedCourses.length > 0) { %>
      <% completedCourses.forEach(item => { %>
        <div class="course-card">
          <span><%= item.course?.title || item.title || "Untitled Course" %></span>
          <button class="view-btn" onclick="goToCertificate()">View Certificate</button>
        </div>
      <% }) %>
    <% } else { %>
      <p>No completed courses yet.</p>
    <% } %>
  </section>
<% } %>


    <!-- SECTION 3 -->
    <% if (user.role === "student") { %>
  <section class="certificates">
    <h2 class="section-title">
      <i class="fa-solid fa-trophy"></i>
      Certificates
    </h2>

    <div class="certificate-grid">
      <% if (certificates && certificates.length > 0) { %>
        <% certificates.forEach(cert => { %>
          <div class="certificate-card">
            <div class="cert-icon"><i class="fa-solid fa-award"></i></div>
            <h3>Certificate of Completion</h3>
            <p>
              Issued:
              <%= cert.issuedAt ? cert.issuedAt.toLocaleDateString() : "N/A" %>
            </p>
          </div>
        <% }) %>
      <% } else { %>
        <p>No certificates yet.</p>
      <% } %>
    </div>
  </section>
<% } %>

<!---------INSTRUCTOR SECTIONS------------->
<% if (user.role === "instructor") { %>
  <section class="completed-courses">
    <h2 class="section-title">
      <i class="fa-solid fa-book-open"></i>
      Created Courses
    </h2>

    <% if (instructorCourses && instructorCourses.length > 0) { %>
      <% instructorCourses.forEach(course => { %>
        <div class="course-card">
          <span><%= course.title %></span>
          <a href="/instructor/courses/<%= course._id %>/students" class="view-btn">
            View Students
          </a>
        </div>
      <% }) %>
    <% } else { %>
      <p>You have not created any courses yet.</p>
    <% } %>
  </section>
<% } %>
<!----------ADMIN SECTION------------->
<% if (user.role === "admin") { %>
  <section class="completed-courses">
    <h2 class="section-title">
      <i class="fa-solid fa-shield-halved"></i>
      Admin Tools
    </h2>

    <div class="course-card">
      <span>Total Users: <%= adminStats?.totalUsers || 0 %></span>
      <a href="/admin/users" class="view-btn">Manage Users</a>
    </div>

    <div class="course-card">
      <span>Total Challenges: <%= adminStats?.totalChallenges || 0 %></span>
      <a href="/admin/manage-challenges" class="view-btn">Manage Challenges</a>
    </div>
  </section>
<% } %>
  </main>
  <script src="/js/profile.js"></script>
</body>
</html>