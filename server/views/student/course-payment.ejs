<!DOCTYPE html>
<html lang="<%= locale || 'en' %>" dir="<%= isRTL ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8"/>
  <link rel="icon" type="image/png" href="/images/favicon.png?v=2" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TheDevStudio | <%= __("payment.pageTitle") %></title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link rel="stylesheet" href="/css/base.css"/>
  <link rel="stylesheet" href="/css/coursepayment.css"/>

</head>

<body>
<%- include('../partials/navbar') %>
  <main class="enroll-wrapper">

    <h1 class="enroll-title"><%= __("payment.pageTitle") %></h1>

    <div class="enroll-grid">

      <!-- LEFT: Course Summary -->
      <aside class="enroll-card">
        <h2><%= __("payment.courseSummary") %></h2>

        <img
          src="<%= course.image || 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&q=80' %>"
          alt="<%= course.title %>"
          class="course-img"
        />

        <h3 class="course-name"><%= course.title %></h3>

        <p class="course-author">
          <%= __("labels.by") %> <%= course.instructorName || course.author || __("payment.defaultInstructor") %>
        </p>

        <p class="course-desc">
          <%= course.description %>
        </p>

        <div class="course-meta">
          <span class="course-rating">
            <i class="fa-solid fa-star"></i>
            <%= course.rating || '4.9' %>
          </span>
          <span class="dot">•</span>
          <span><%= course.duration || '12 hours' %></span>
        </div>

        <p class="course-price">
          $<%= Number(course.price || 0).toFixed(2) %>
        </p>

        <p class="course-access"><%= __("payment.oneTimeLifetime") %></p>

        <hr class="divider"/>

        <div class="guarantee">
          <i class="fa-regular fa-circle-check"></i>
          <%= __("payment.moneyBack") %>
        </div>
      </aside>

      <!-- RIGHT: Payment Form -->
      <section class="enroll-card">

        <div class="payment-header">
          <div class="payment-icon">
            <i class="fa-solid fa-credit-card"></i>
          </div>
          <div>
            <h2><%= __("payment.paymentInfo") %></h2>
            <p class="payment-sub"><%= __("payment.secureEncrypted") %></p>
          </div>
        </div>
        <div class="payment-content">
  <div class="payment-form-column">
       <form id="paymentForm" action="/student/payment/<%= course._id %>" method="POST">
        <input type="hidden" id="cardType" name="cardType" value="unknown">

          <div class="field-group">
            <label for="cardName"><%= __("payment.cardholderName") %></label>
            <input type="text" placeholder="<%= __('payment.cardholderPlaceholder') %>" id="cardName" name="cardName"/>
            <span class="field-error" id="err-cardName"></span>
          </div>

          <div class="field-group">
  <label for="cardNumber"><%= __("payment.cardNumber") %></label>

  <div class="input-row">
    <input 
      type="text" 
      placeholder="<%= __('payment.cardNumberPlaceholder') %>" 
      id="cardNumber" 
      name="cardNumber" 
      maxlength="19"
    />

    <div class="card-brands">
      <span class="brand visa" id="brandVisa">VISA</span>
      <span class="brand mc" id="brandMastercard">MC</span>
    </div>
  </div>

  <span class="field-error" id="err-cardNumber"></span>
</div>

          <div class="two-col">
            <div class="field-group">
              <label for="expiry"><%= __("payment.expiryDate") %></label>
              <input type="text" placeholder="<%= __('payment.expiryPlaceholder') %>" id="expiry" name="expiry" maxlength="5"/>
              <span class="field-error" id="err-expiry"></span>
            </div>

            <div class="field-group">
              <label for="cvv"><%= __("payment.cvv") %></label>
              <input type="text" placeholder="<%= __('payment.cvvPlaceholder') %>" id="cvv" name="cvv" maxlength="3"/>
              <span class="field-error" id="err-cvv"></span>
            </div>
          </div>

          <!-- CARD PREVIEW — inline between CVV and Promo -->
          <div class="inline-card-preview">
            <div class="credit-card" id="creditCard">
              <div class="card-face card-front">
                <div class="card-top">
                  <div class="card-chip"></div>
                  <span class="card-brand-preview" id="previewBrand">CARD</span>
                </div>
                <div class="preview-card-number" id="previewCardNumber">#### #### #### ####</div>
                <div class="card-bottom">
                  <div>
                    <span class="card-small-label"><%= __("payment.cardHolder") %></span>
                    <strong id="previewCardName"><%= __("payment.yourName") %></strong>
                  </div>
                  <div>
                    <span class="card-small-label"><%= __("payment.expires") %></span>
                    <strong id="previewExpiry">MM/YY</strong>
                  </div>
                </div>
              </div>
              <div class="card-face card-back">
                <div class="card-strip"></div>
                <div class="card-cvv-row">
                  <span>CVV</span>
                  <div class="card-cvv-box" id="previewCvv">###</div>
                </div>
              </div>
            </div>
          </div>

          <div class="field-group">
            <label for="promo"><%= __("payment.promoCode") %></label>
            <input type="text" placeholder="<%= __('payment.promoPlaceholder') %>" id="promo" name="promo"/>
            <span class="field-error" id="err-promo"></span>
          </div>

          <!-- Order Summary -->
          <div class="order-summary">
            <% const subtotal = Number(course.price || 0); %>
            <% const tax = subtotal * 0.14; %>
            <% const total = subtotal + tax; %>
            <div class="order-row">
              <span><%= __("labels.subtotal") %></span>
              <span id="subtotal" data-subtotal="<%= subtotal.toFixed(2) %>">$<%= subtotal.toFixed(2) %></span>
            </div>

            <div class="order-row">
              <span><%= __("labels.tax") %></span>
              <span id="tax" data-tax-rate="0.14">$<%= tax.toFixed(2) %></span>
            </div>

            <div class="order-row total-row">
              <span><%= __("labels.total") %></span>
              <span id="total" class="total-amount">
                $<%= total.toFixed(2) %>
              </span>
            </div>
          </div>

          <!-- Terms -->
          <div class="field-group">
            <div class="terms-row">
              <input type="checkbox" id="terms" name="terms"/>
              <label for="terms" class="terms-check-label"><%= __("payment.termsAgree") %></label>
              <button type="button" class="terms-link-btn" id="open-terms"><%= __("payment.termsOfService") %></button>
              <span class="terms-label-text"> <%= __("payment.and") %> </span>
              <button type="button" class="terms-link-btn" id="open-privacy"><%= __("payment.privacyPolicy") %></button>
            </div>
            <span class="field-error" id="err-terms"></span>
          </div>

          <!-- Confirm Button -->
          <button class="btn-confirm" id="confirmBtn" type="submit">
            <i class="fa-solid fa-lock"></i>
            <%= __("buttons.confirmPayment") %>
          </button>

        </form>
          </div><!-- /payment-form-column -->
</div><!-- /payment-content -->

        <p class="secure-note">
          <i class="fa-solid fa-lock"></i>
          <%= __("payment.secureNote") %>
        </p>

        <a href="/courses/all-courses" class="back-link">← <%= __("payment.backToCourses") %></a>

      </section>
    </div>
  </main>

  <!-- Terms popup (summary) -->
  <div class="payment-popup hidden" id="terms-modal" aria-hidden="true">
    <div class="payment-popup-card terms-modal-card" role="dialog">
      <button type="button" class="terms-modal-close" id="terms-modal-close" aria-label="Close">
        <i class="fa-solid fa-xmark"></i>
      </button>
            <h3><%= __("payment.termsTitle") %></h3>
      <div class="terms-modal-body">
        <p><%= __("payment.termsIntro") %></p>
        <ul>
          <li><%= __("payment.termsItem1") %></li>
          <li><%= __("payment.termsItem2") %></li>
          <li><%= __("payment.termsItem3") %></li>
          <li><%= __("payment.termsItem4") %></li>
        </ul>
        <a href="/auth/terms-of-services" target="_blank" rel="noopener noreferrer" class="legal-full-link">
          <%= __("payment.readFullTerms") %>
        </a>
      </div>
      <button type="button" class="btn-confirm terms-modal-close-btn" id="terms-modal-close-btn">
        <%= __("buttons.close") %>
      </button>
    </div>
  </div>

  <!-- Privacy popup (summary) -->
  <div class="payment-popup hidden" id="privacy-modal" aria-hidden="true">
    <div class="payment-popup-card terms-modal-card" role="dialog">
      <button type="button" class="terms-modal-close" id="privacy-modal-close" aria-label="Close">
        <i class="fa-solid fa-xmark"></i>
      </button>
      <h3><%= __("payment.privacyTitle") %></h3>
      <div class="terms-modal-body">
        <p><%= __("payment.privacyIntro") %></p>
        <ul>
          <li><%= __("payment.privacyItem1") %></li>
          <li><%= __("payment.privacyItem2") %></li>
          <li><%= __("payment.privacyItem3") %></li>
        </ul>
        <p><%= __("payment.privacyNoSell") %></p>
        <a href="/auth/privacy-policy" target="_blank" rel="noopener noreferrer" class="legal-full-link">
          <%= __("payment.readFullPrivacy") %>
        </a>
      </div>
      <button type="button" class="btn-confirm terms-modal-close-btn" id="privacy-modal-close-btn">
        <%= __("buttons.close") %>
      </button>
    </div>
  </div>

  <script src="/js/coursepayment.js"></script>
 

</body>
</html>
