<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>TheDevStudio | Payment Successful</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link rel="stylesheet" href="/css/payment-result.css"/>
 
</head>

<body>
  <%- include('../partials/navbar') %>
  <main class="page">
    <section class="payment-layout">

      <section class="payment-card" style="max-width: 650px; margin: 0 auto; text-align: center;">

        <div class="payment-header">
          <div class="payment-icon payment-icon--success">
            <i class="fa-solid fa-circle-check"></i>
          </div>
          <div>
            <h2>Payment Successful</h2>
            <p>Your enrollment has been completed successfully.</p>
          </div>
        </div>

        <p class="description">
          You now have lifetime access to this course. You can start learning immediately from your dashboard.
        </p>

        <% if (typeof course !== "undefined" && course) { %>
          <div class="summary-box">
            <div class="summary-row">
              <span>Course</span>
              <span><%= course.title || "Course" %></span>
            </div>

            <div class="summary-row">
              <span>Instructor</span>
              <span><%= course.instructorName || course.author || "Instructor" %></span>
            </div>

            <div class="summary-row total">
              <span>Amount Paid</span>
              <span>
                $<%= payment && payment.amount != null ? Number(payment.amount).toFixed(2) : "0.00" %>
              </span>
            </div>
          </div>
        <% } else { %>
          <div class="summary-box">
            <div class="summary-row total">
              <span>Status</span>
              <span>Enrollment Confirmed</span>
            </div>
          </div>
        <% } %>

        <div class="result-actions">
          <a href="/courses/all-courses" class="confirm-btn">
            Browse more courses
          </a>
          <a href="/student/my-courses" class="back-link">
            Go to my courses →
          </a>
        </div>

      </section>

    </section>
  </main>

  <script src="/js/student.js"></script>

</body>
</html>
