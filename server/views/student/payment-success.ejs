<!DOCTYPE html>
<html lang="<%= locale || 'en' %>" dir="<%= isRTL ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/images/favicon.png?v=2" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>TheDevStudio | <%= __("payment.successTitle") %></title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link rel="stylesheet" href="/css/payment-result.css"/>
 
</head>

<body>
  <%- include('../partials/navbar') %>
  <main class="page">
    <section class="payment-layout">

      <section class="payment-card" style="max-width: 650px; margin: 0 auto; text-align: center;">

        <div class="payment-header">
          <div class="payment-icon payment-icon--success">
            <i class="fa-solid fa-circle-check"></i>
          </div>
          <div>
            <h2><%= __("payment.successTitle") %></h2>
<p><%= __("payment.successSubtitle") %></p>
          </div>
        </div>

        <p class="description">
          <%= __("payment.successDescription") %>
        </p>

        <% if (typeof course !== "undefined" && course) { %>
          <div class="summary-box">
            <div class="summary-row">
              <span><%= __("payment.course") %></span>
              <span><%= course.title || __("payment.course") %></span>
            </div>

            <div class="summary-row">
              <span><%= __("payment.instructor") %></span>
              <span><%= course.instructorName || course.author || __("payment.instructor") %></span>
            </div>

            <div class="summary-row total">
              <span><%= __("payment.amountPaid") %></span>
              <span>
                $<%= payment && payment.amount != null ? Number(payment.amount).toFixed(2) : "0.00" %>
              </span>
            </div>
          </div>
        <% } else { %>
          <div class="summary-box">
            <div class="summary-row total">
              <span><%= __("payment.status") %></span>
              <span><%= __("payment.enrollmentConfirmed") %></span>
            </div>
          </div>
        <% } %>

        <div class="result-actions">
          <a href="/courses/all-courses" class="confirm-btn">
            <%= __("payment.browseMoreCourses") %>
          </a>
          <a href="/student/my-courses" class="back-link">
            <%= __("payment.goToMyCourses") %> →
          </a>
        </div>

      </section>

    </section>
  </main>

  <script src="/js/student.js"></script>

</body>
</html>
