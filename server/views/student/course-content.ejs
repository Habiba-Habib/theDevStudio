<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= course.title %> – Learn</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/course-content.css"/>
</head>
<body>

<%- include('../partials/navbar') %>

<%
  let activeLesson       = null;
  let activeSectionTitle = '';
  let prevLessonId       = null;
  let nextLessonId       = null;
  const allLessons       = [];
  course.sections.forEach(s => s.lessons.forEach(l => allLessons.push(l)));
  const activeIndex = allLessons.findIndex(l => l._id.toString() === activeLessonId);
  if (activeIndex !== -1) {
    activeLesson  = allLessons[activeIndex];
    prevLessonId  = activeIndex > 0 ? allLessons[activeIndex - 1]._id : null;
    nextLessonId  = activeIndex < allLessons.length - 1 ? allLessons[activeIndex + 1]._id : null;
  }
  course.sections.forEach(s => {
    if (s.lessons.some(l => l._id.toString() === activeLessonId)) activeSectionTitle = s.title;
  });
  const isActiveDone = activeLesson && completedLessons.includes(activeLesson._id.toString());
  const sidebarPct   = totalLessons > 0 ? Math.round((completedLessons.length / totalLessons) * 100) : 0;
  const canCompleteLessons = user?.role === 'student' && !isInstructorOwner;
%>

<!-- ── COURSE HEADER (below navbar) ── -->
<div class="course-header">
  <div class="ch-left">
    <div class="ch-course-title"><%= course.title %></div>
    <% if (activeLesson) { %>
      <div class="ch-lesson-name"><%= activeLesson.title %></div>
    <% } %>
  </div>
  <div class="ch-right">
    <span class="ch-prog-label">Course Progress</span>
    <span class="ch-prog-pct" id="topbarPct"><%= enrollment.progress %>%</span>
  </div>
  <div class="ch-bar">
    <div class="ch-bar-fill" id="topbarFill" data-progress="<%= enrollment.progress || 0 %>"></div>
  </div>
</div>

<!-- ── PAGE BODY ── -->
<div class="page-body">

  <!-- LEFT COLUMN -->
  <div class="left-col">

    <!-- VIDEO CARD (only when a lesson is selected) -->
    <% if (activeLesson) { %>
      <div class="video-card">
        <% if (activeLesson.type === 'video') { %>
          <%
            const useUpload = activeLesson.videoSource === 'upload';
            let videoSrc = useUpload
              ? (activeLesson.videoFile || activeLesson.videoUrl || '')
              : (activeLesson.videoUrl || activeLesson.videoFile || '');
            let embedUrl = videoSrc;
            if (videoSrc) {
              const ytMatch = videoSrc.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
              if (ytMatch) embedUrl = 'https://www.youtube.com/embed/' + ytMatch[1];
            }
          %>
          <% if (embedUrl) { %>
            <% if (embedUrl.includes('youtube.com/embed') || embedUrl.includes('youtu.be') || embedUrl.includes('vimeo.com')) { %>
              <iframe class="video-frame" src="<%= embedUrl %>" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen></iframe>
            <% } else { %>
              <video class="video-frame" controls controlsList="nodownload">
                <source src="<%= embedUrl %>">
                Your browser does not support the video tag.
              </video>
            <% } %>
          <% } else { %>
            <div class="video-placeholder">
              <div class="vp-play">&#9654;</div>
              <p class="vp-title">Video Player</p>
              <p class="vp-sub">Click to play lesson</p>
            </div>
          <% } %>
        <% } %>
        <% if (activeLesson.type === 'text') { %>
          <div class="text-lesson">
            <% if (activeLesson.content) { %>
              <%- activeLesson.content %>
            <% } else { %>
              <p class="empty-text">No content added yet.</p>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="no-lesson">
        <i class="fa-solid fa-book-open"></i>
        <p>Select a lesson from the sidebar to start learning.</p>
      </div>
    <% } %>

    <!-- LESSON INFO CARD (always visible) -->
    <div class="info-card">
      <h2 class="info-title"><%= activeLesson ? activeLesson.title : course.title %></h2>
      <p class="info-desc"><%= course.shortDescription || '' %></p>

      <% if (course.learningOutcomes && course.learningOutcomes.length) { %>
        <h4 class="info-heading">Learning Objectives</h4>
        <ul class="objectives">
          <% course.learningOutcomes.forEach(o => { %>
            <li><i class="fa-solid fa-circle-check"></i><span><%= o %></span></li>
          <% }) %>
        </ul>
      <% } %>

      <h4 class="info-heading">Downloadable Resources</h4>
      <div class="resources">
        <% if (activeLesson && activeLesson.resourceFile) { %>
          <%
            const resFileName = decodeURIComponent(activeLesson.resourceFile.split('/').pop().split('?')[0]);
            const hasDot      = resFileName.includes('.');
            const resExt      = hasDot ? resFileName.split('.').pop().toLowerCase() : '';
            const isFallbackPdf = !hasDot;
            const finalExt    = isFallbackPdf ? 'pdf' : resExt;
            const resIconMap  = {
              pdf:  'fa-file-pdf',
              doc:  'fa-file-word',  docx: 'fa-file-word',
              ppt:  'fa-file-powerpoint', pptx: 'fa-file-powerpoint',
              xls:  'fa-file-excel', xlsx: 'fa-file-excel',
              zip:  'fa-file-zipper', rar: 'fa-file-zipper',
              mp4:  'fa-file-video', mkv: 'fa-file-video', avi: 'fa-file-video', mov: 'fa-file-video',
            };
            const resIcon  = resIconMap[finalExt] || 'fa-file';
            const resLabel = finalExt ? finalExt.toUpperCase() + ' File' : 'File';
            const customName = isFallbackPdf ? (resFileName + '.pdf') : resFileName;
          %>
          <a class="resource-item" href="/student/course/<%= course._id %>/lesson/<%= activeLesson._id %>/download-resource" download="<%= customName %>">
            <span class="res-file-icon"><i class="fa-solid <%= resIcon %>"></i></span>
            <div class="res-info">
              <div class="res-name"><%= resFileName %></div>
              <div class="res-size"><%= resLabel %></div>
            </div>
            <span class="res-dl"><i class="fa-solid fa-download"></i></span>
          </a>
        <% } else { %>
          <p class="res-empty">No resources attached to this lesson.</p>
        <% } %>
      </div>
    </div>

    <!-- TABS CARD (always visible) -->
    <div class="tabs-card">
      <div class="tabs-nav">
        <button class="tab-btn active" data-tab="overview">Overview</button>
        <button class="tab-btn" data-tab="notes">Notes</button>
        <button class="tab-btn" data-tab="quiz">Assignments</button>
      </div>

      <div class="tab-pane active" id="tab-overview">
        <div class="instructor-row">
          <img class="inst-avatar"
            src="<%= course.instructor?.avatar ? '/images/avatars/' + course.instructor.avatar : '/images/avatars/avatar1g.png' %>"
            alt="<%= course.instructor?.name %>"/>
          <div class="inst-info">
            <span class="inst-label">Instructor</span>
            <span class="inst-name"><%= course.instructor?.name || 'Unknown' %></span>
            <% if (canCompleteLessons && course.instructor?.email) { %>
              <a href="mailto:<%= course.instructor.email %>" class="inst-email">
                <i class="fa-solid fa-envelope"></i> <%= course.instructor.email %>
              </a>
            <% } %>
          </div>
        </div>
        <p class="info-desc"><%= course.shortDescription || '' %></p>
      </div>

      <div class="tab-pane" id="tab-notes">
        <% if (activeLesson) { %>
          <div class="notes-wrap">
            <div class="notes-header">
              <span class="notes-title"><i class="fa-solid fa-pen-to-square"></i> My Notes</span>
              <span class="notes-saved-label" id="notesSavedLabel"></span>
            </div>
            <textarea
              class="notes-textarea"
              id="notesTextarea"
              placeholder="Write your notes for this lesson here…"
              data-course-id="<%= course._id %>"
              data-lesson-id="<%= activeLesson._id %>"
            ><%= activeNote || '' %></textarea>
            <div class="notes-footer">
              <span class="notes-hint"><i class="fa-regular fa-lightbulb"></i> Notes are saved per lesson automatically.</span>
              <button class="notes-save-btn" id="notesSaveBtn">
                <i class="fa-solid fa-floppy-disk"></i> Save Note
              </button>
            </div>
          </div>
        <% } else { %>
          <p class="pane-empty">Select a lesson to start taking notes.</p>
        <% } %>
      </div>

      <div class="tab-pane" id="tab-quiz">
        <% if (activeLesson && activeLesson.assignmentFile) { %>
          <%
            const aFileName = decodeURIComponent(activeLesson.assignmentFile.split('/').pop().split('?')[0]);
            const aHasDot   = aFileName.includes('.');
            const aExt      = aHasDot ? aFileName.split('.').pop().toLowerCase() : 'pdf';
            const aIconMap  = { pdf: 'fa-file-pdf', doc: 'fa-file-word', docx: 'fa-file-word', ppt: 'fa-file-powerpoint', pptx: 'fa-file-powerpoint' };
            const aIcon     = aIconMap[aExt] || 'fa-file-lines';
            const aLabel    = aExt.toUpperCase() + ' File';
          %>
          <div class="assignment-wrap">
            <div class="assignment-header">
              <i class="fa-solid fa-clipboard-list assignment-icon"></i>
              <div>
                <div class="assignment-title">Assignment</div>
                <div class="assignment-sub">Download the file, complete it, and submit below.</div>
              </div>
            </div>

            <!-- Download -->
            <a class="resource-item assignment-download"
               href="/student/course/<%= course._id %>/lesson/<%= activeLesson._id %>/download-assignment"
               download="<%= aFileName %>">
              <span class="res-file-icon"><i class="fa-solid <%= aIcon %>"></i></span>
              <div class="res-info">
                <div class="res-name"><%= aFileName %></div>
                <div class="res-size"><%= aLabel %></div>
              </div>
              <span class="res-dl"><i class="fa-solid fa-download"></i></span>
            </a>

            <!-- Submit -->
            <% if (!isInstructorOwner) { %>
            <div class="submit-assignment-wrap">
              <div class="submit-header">
                <i class="fa-solid fa-upload submit-icon"></i>
                <div>
                  <div class="submit-title">Submit Your Work</div>
                  <div class="submit-sub">Upload your completed assignment (PDF, DOC, DOCX, PPT, PPTX)</div>
                </div>
              </div>

              <% if (activeSubmission) { %>
                <div class="submission-existing" id="submissionExisting">
                  <i class="fa-solid fa-circle-check"></i>
                  <div class="submission-existing-info">
                    <span class="submission-existing-name"><%= activeSubmission.fileName %></span>
                    <span class="submission-existing-date">Submitted <%= new Date(activeSubmission.submittedAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %></span>
                  </div>
                  <button class="btn-resubmit" id="btnResubmit">Resubmit</button>
                </div>
              <% } %>

              <div class="submit-form <%= activeSubmission ? 'hidden' : '' %>" id="submitForm">
                <label class="upload-drop-zone" id="uploadDropZone" for="submissionFileInput">
                  <i class="fa-solid fa-cloud-arrow-up"></i>
                  <span class="drop-label">Click to choose file or drag & drop</span>
                  <span class="drop-hint" id="dropHint">PDF, DOC, DOCX, PPT, PPTX • Max 50MB</span>
                </label>
                <input type="file" id="submissionFileInput" accept=".pdf,.doc,.docx,.ppt,.pptx" style="display:none"
                  data-course-id="<%= course._id %>"
                  data-lesson-id="<%= activeLesson._id %>"
                />
                <button class="notes-save-btn" id="btnSubmitAssignment" disabled>
                  <i class="fa-solid fa-paper-plane"></i> Submit Assignment
                </button>
              </div>
            </div>
            <% } %>

          </div>
        <% } else { %>
          <p class="pane-empty">No assignment for this lesson.</p>
        <% } %>
      </div>
    </div>

  </div><!-- /left-col -->

  <!-- RIGHT SIDEBAR -->
  <aside class="sidebar-col">

    <div class="sidebar-card">
      <div class="sidebar-head">Course Curriculum</div>

      <div class="sidebar-prog-wrap">
        <div class="sidebar-prog-row">
          <span class="sidebar-prog-label">Progress</span>
          <span class="sidebar-prog-count" id="sidebarCount"><%= completedLessons.length %>/<%= totalLessons %></span>
        </div>
        <div class="sidebar-prog-track">
          <div class="sidebar-prog-fill" id="sidebarFill" data-progress="<%= sidebarPct || 0 %>"></div>
        </div>
      </div>

      <div class="sidebar-list">
        <% course.sections.forEach(function(section) { %>

          <div class="section-label"><%= section.title %></div>

          <% section.lessons.forEach(function(lesson) {
            const isDone   = completedLessons.includes(lesson._id.toString());
            const isActive = lesson._id.toString() === activeLessonId;
          %>
            <a class="lesson-row <%= isActive ? 'is-active' : '' %> <%= isDone ? 'is-done' : '' %>"
               href="/student/course/<%= course._id %>/learn?lesson=<%= lesson._id %>"
               data-lesson-id="<%= lesson._id %>">
              <span class="lesson-row-icon">
                <% if (isDone) { %>
                  <i class="fa-solid fa-circle-check"></i>
                <% } else if (isActive) { %>
                  <span class="play-tri">&#9654;</span>
                <% } else { %>
                  <i class="fa-regular fa-circle"></i>
                <% } %>
              </span>
              <span class="lesson-row-body">
                <span class="lesson-row-title"><%= lesson.title %></span>
                <% if (lesson.duration) { %>
                  <span class="lesson-row-dur"><%= lesson.duration %></span>
                <% } %>
              </span>
            </a>
          <% }) %>

        <% }) %>
      </div>
    </div>

  </aside>

</div><!-- /page-body -->

<!-- ── FIXED BOTTOM NAV ── -->
<div class="bottom-nav" data-course-id="<%= course._id %>" data-total="<%= totalLessons %>" data-completed="<%= completedLessons.length %>">

  <% if (prevLessonId) { %>
    <a class="btn-prev" href="/student/course/<%= course._id %>/learn?lesson=<%= prevLessonId %>">
      <i class="fa-solid fa-chevron-left"></i> Previous Lesson
    </a>
  <% } else { %>
    <span class="btn-prev is-disabled">
      <i class="fa-solid fa-chevron-left"></i> Previous Lesson
    </span>
  <% } %>

  <% if (canCompleteLessons && activeLesson) { %>
    <button class="btn-mark <%= isActiveDone ? 'is-done' : '' %>"
      id="btnComplete"
      data-course-id="<%= course._id %>"
      data-lesson-id="<%= activeLesson._id %>">
      <i class="fa-solid fa-check"></i>
      <%= isActiveDone ? 'Completed' : 'Mark Complete' %>
    </button>
  <% } else if (canCompleteLessons) { %>
    <span class="btn-mark is-disabled">
      <i class="fa-solid fa-check"></i> Mark Complete
    </span>
  <% } %>

  <% if (nextLessonId) { %>
    <a class="btn-next" href="/student/course/<%= course._id %>/learn?lesson=<%= nextLessonId %>">
      Next Lesson <i class="fa-solid fa-chevron-right"></i>
    </a>
  <% } else if (user?.role === 'admin') { %>
    <a class="btn-next" href="/admin/course-applications?course=<%= course._id %>">
      <i class="fa-solid fa-chevron-left"></i> Back to Course Details
    </a>
  <% } else if (!canCompleteLessons) { %>
    <a class="btn-next" href="/courses/<%= course._id %>">
      <i class="fa-solid fa-chevron-left"></i> Back to Course Description
    </a>
  <% } else { %>
    <span class="btn-next is-disabled">
      Next Lesson <i class="fa-solid fa-chevron-right"></i>
    </span>
  <% } %>

</div>

<!-- ── COURSE COMPLETION MODAL ── -->
<div class="completion-overlay" id="completionOverlay">
  <div class="completion-modal">
    <div class="cm-confetti">
      <i class="fa-solid fa-trophy"></i>
    </div>
    <h2 class="cm-title">Course Complete!</h2>
    <p class="cm-sub">You've finished <strong><%= course.title %></strong>. We'd love to hear what you think.</p>

    <div class="cm-stars" id="cmStars">
      <% for (let i = 1; i <= 5; i++) { %>
        <button class="cm-star" data-value="<%= i %>" aria-label="<%= i %> star">
          <i class="fa-regular fa-star"></i>
        </button>
      <% } %>
    </div>
    <p class="cm-star-label" id="cmStarLabel">Tap a star to rate</p>

    <textarea class="cm-textarea" id="cmComment" placeholder="Share your thoughts (optional)…" rows="3"></textarea>

    <div class="cm-actions">
      <button class="cm-btn-submit" id="cmSubmit" disabled>
        <i class="fa-solid fa-paper-plane"></i> Submit Review
      </button>
      <a class="cm-btn-courses" href="/student/my-courses">
        <i class="fa-solid fa-graduation-cap"></i> Back to My Courses
      </a>
    </div>
    <button class="cm-skip" id="cmSkip">Skip for now</button>
  </div>
</div>

<script src="/js/course-content.js"></script>
</body>
</html>
