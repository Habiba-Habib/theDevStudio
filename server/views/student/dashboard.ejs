<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Dashboard</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
   <link rel="stylesheet" href="/css/dashboards.css" />
  
</head>
<body>
<%- include('../partials/navbar') %>
  <main class="main-content">
    <div class="page-grid">

      <!-- Left Column -->
      <div class="page-left">

        <section class="welcome-section">
          <h1 class="welcome-title">Welcome back, <%= user.name %>!</h1>
          <p class="welcome-subtitle"><%= user.welcomeMessage %></p>
        </section>
        
        <!-- Stats -->
        <section class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon stat-icon--pink">
              <i class="fa-solid fa-book-open"></i>
            </div>
            <div class="stat-value"><%= stats.enrolledCourses %></div>
            <div class="stat-label">Enrolled Courses</div>
            <div class="stat-change"><%= stats.enrolledChange %></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon stat-icon--green">
              <i class="fa-solid fa-arrow-trend-up"></i>
            </div>
            <div class="stat-value"><%= stats.progress %>%</div>
            <div class="stat-label">Progress</div>
            <div class="stat-change"><%= stats.progressChange %></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon stat-icon--teal">
              <i class="fa-solid fa-trophy"></i>
            </div>
            <div class="stat-value">#<%= stats.rank %></div>
            <div class="stat-label">Rank</div>
            <div class="stat-change"><%= stats.rankLabel %></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon stat-icon--purple">
              <i class="fa-solid fa-bolt-lightning"></i>
            </div>
            <div class="stat-value"><%= stats.totalPoints.toLocaleString() %></div>
            <div class="stat-label">Total Points</div>
            <div class="stat-change"><%= stats.pointsChange %></div>
          </div>
        </section>

        <!-- My Current Courses -->
        <section class="section-block">
          <div class="section-header">
            <h2 class="section-title">My Current Courses</h2>
           <a href="/student/my-courses" class="section-link">View All</a>
          </div>

                    <div class="courses-list">
          <% if (courses.length === 0) { %>
            <p class="empty-courses">You haven't enrolled in any courses yet.</p>
          <% } %>

          <% courses.forEach(function(course) { %>
          <div class="course-progress-card">
            <img
              src="<%= course.thumbnail || '/images/course1.jpg' %>"
              alt="<%= course.title %>"
              class="course-thumb"
            />
            <div class="course-progress-info">
              <div class="course-progress-top">
                <div>
                  <h3 class="course-progress-title"><%= course.title %></h3>
                  <p class="course-progress-author">By <%= course.instructor %></p>
                </div>
                <span class="progress-badge"><%= course.progress %>% Complete</span>
              </div>
              <div class="progress-bar-wrapper">
                <div class="progress-bar" data-width="<%= course.progress %>"></div>
              </div>
              <a href="/student/course/<%= course._id %>/learn" class="btn-continue">Continue Learning</a>
            </div>
          </div>
          <% }); %>
          </div>
        
          <!-- Action Buttons -->
          <div class="courses-actions">
            <a href="/courses/all-courses" class="btn-explore">
              <i class="fa-solid fa-book-open"></i>
              Explore More Courses
            </a>
          </div>
        </section>

        <!-- Upcoming Challenges -->
        <section class="section-block">
          <div class="section-header">
            <h2 class="section-title">Upcoming Challenges</h2>
            <a href="/challenges" class="section-link">View All →</a>
          </div>
          <div class="challenges-grid">
           <% challenges.forEach(function(challenge) { %>
  <a href="/student/start-challenge/<%= challenge._id %>" class="challenge-card">
    <div class="challenge-card-top">
      <span class="challenge-badge challenge-badge--<%= challenge.difficulty.toLowerCase() %>"><%= challenge.difficulty %></span>
      <span class="challenge-pts">
        <i class="fa-solid fa-bolt-lightning"></i>
        <%= challenge.points %> pts
      </span>
    </div>

    <h3 class="challenge-title"><%= challenge.title %></h3>

    <p class="challenge-due">
      <i class="fa-regular fa-clock"></i>
      Due in <%= challenge.dueInDays %> days
    </p>
  </a>
<% }); %>
          </div>
        </section>

      </div>

      <!-- Right Column — Leaderboard -->
      <aside class="page-right">
        <div class="leaderboard-card">
          <div class="leaderboard-header">
            <h2 class="leaderboard-title">Leaderboard</h2>
            <a href="/student/leaderboard" class="leaderboard-link">View Full</a>
          </div>
          <div class="leaderboard-list">

           <% leaderboard.forEach(function(entry, index) { %>
            <div class="lb-item<%= index === 0 ? ' lb-item--first' : '' %>">
            <div class="lb-rank lb-rank--<%= entry.rank %>"><%= entry.rank %></div>
            <img src="<%= entry.avatar %>" alt="avatar" class="lb-avatar" />
              <div class="lb-info">
                <div class="lb-name"><%= entry.name %></div>
                <div class="lb-pts"><%= entry.points.toLocaleString() %> pts</div>
              </div>
             <% if (entry.rank === 1) { %>
                  <i class="fa-solid fa-trophy lb-trophy"></i>
                <% } else if (entry.rank === 2) { %>
                  <i class="fa-solid fa-trophy lb-trophy lb-trophy--silver"></i>
                <% } else if (entry.rank === 3) { %>
                  <i class="fa-solid fa-trophy lb-trophy lb-trophy--bronze"></i>
                 <% } %>
                  </div>       
                  <% }); %>
                  </div>
          </div>
  <!-- Instructor Application Status -->
        <section class="section-block">
         
          <% if (user.instructorStatus === 'approved') { %>
            <div class="instructor-status-card approved">
              <div class="status-icon"><i class="fa-solid fa-check-circle"></i></div>
              <div class="status-content">
                <h3>Application Approved</h3>
              </div>
   <button onclick="showActivateModal()" class="btn-signup">Activate</button>
            </div>
          <% } else if (user.instructorStatus === 'pending') { %>
            <div class="instructor-status-card pending">
              <div class="status-icon"><i class="fa-solid fa-clock"></i></div>
              <div class="status-content">
                <h3>Application Pending</h3>
              </div>
            </div>
          <% } else if (user.instructorStatus === 'rejected') { %>
    <div class="instructor-status-card rejected" data-reason="<%= user.instructorVerification?.rejectionReason || 'No reason provided' %>">
  <div class="status-icon"><i class="fa-solid fa-times-circle"></i></div>
  <div class="status-content">
    <h3>Application Rejected</h3>
    <p>Your application was not approved.</p>
    <button onclick="showRejectionReason(this)" class="btn-secondary">View Reason</button>
  </div>
</div>

        
          <% } %>
        </section>
          
        </div>
      </aside>

    </div>
  </main>
        <div id="reasonModal" class="reason-modal" style="display: none;">
      <div class="reason-modal-content">
        <h3>Rejection Reason</h3>
        <p id="rejectionReasonText"></p>
        <button onclick="closeReasonModal()" class="btn-close">Close</button>
      </div>
    </div>
    <!-- Activate Instructor Confirmation Modal -->
<div id="activateModal" class="reason-modal" style="display: none;">
  <div class="reason-modal-content activate-modal-content">
    <div class="activate-modal-icon">
      <i class="fa-solid fa-chalkboard-user"></i>
    </div>
    <h3>Become an Instructor</h3>
    <p>You're about to switch your account to <strong>Instructor mode</strong>.</p>
    <ul class="activate-modal-list">
      <li><i class="fa-solid fa-circle-check"></i> You'll be redirected to log in again</li>
      <li><i class="fa-solid fa-circle-check"></i> Your student progress is saved</li>
      <li><i class="fa-solid fa-circle-check"></i> You'll land on your Instructor Dashboard</li>
    </ul>
    <p class="activate-modal-note">This action cannot be undone from the student side.</p>
    <div class="activate-modal-actions">
      <button onclick="closeActivateModal()" class="btn-close">Cancel</button>
      <button onclick="confirmActivate()" class="btn-signup">Yes, Activate</button>
    </div>
  </div>
</div>

  <script src="/js/dashboards.js"></script>
</body>
</html>
