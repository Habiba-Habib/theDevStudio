<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Dashboard</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
   <link rel="stylesheet" href="/css/dashboards.css" />
   <link rel="stylesheet" href="/css/navbar-css.css">
</head>
<body>

  <main class="main-content">
    <div class="page-grid">

      <!-- Left Column -->
      <div class="page-left">

        <section class="welcome-section">
          <h1 class="welcome-title">Welcome back, <%= user.name %>!</h1>
          <p class="welcome-subtitle"><%= user.welcomeMessage %></p>
        </section>
        
        <!-- Stats -->
        <section class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon stat-icon--pink">
              <i class="fa-solid fa-book-open"></i>
            </div>
            <div class="stat-value"><%= stats.enrolledCourses %></div>
            <div class="stat-label">Enrolled Courses</div>
            <div class="stat-change"><%= stats.enrolledChange %></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon stat-icon--green">
              <i class="fa-solid fa-arrow-trend-up"></i>
            </div>
            <div class="stat-value"><%= stats.progress %>%</div>
            <div class="stat-label">Progress</div>
            <div class="stat-change"><%= stats.progressChange %></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon stat-icon--teal">
              <i class="fa-solid fa-trophy"></i>
            </div>
            <div class="stat-value">#<%= stats.rank %></div>
            <div class="stat-label">Rank</div>
            <div class="stat-change"><%= stats.rankLabel %></div>
          </div>
          <div class="stat-card">
            <div class="stat-icon stat-icon--purple">
              <i class="fa-solid fa-bolt-lightning"></i>
            </div>
            <div class="stat-value"><%= stats.totalPoints.toLocaleString() %></div>
            <div class="stat-label">Total Points</div>
            <div class="stat-change"><%= stats.pointsChange %></div>
          </div>
        </section>

        <!-- My Current Courses -->
        <section class="section-block">
          <div class="section-header">
            <h2 class="section-title">My Current Courses</h2>
           <a href="/student/my-courses" class="section-link">View All</a>
          </div>

                    <div class="courses-list">
          <% if (courses.length === 0) { %>
            <p class="empty-courses">You haven't enrolled in any courses yet.</p>
          <% } %>

          <% courses.forEach(function(course) { %>
          <div class="course-progress-card">
            <img
              src="<%= course.thumbnail || '/images/course1.jpg' %>"
              alt="<%= course.title %>"
              class="course-thumb"
            />
            <div class="course-progress-info">
              <div class="course-progress-top">
                <div>
                  <h3 class="course-progress-title"><%= course.title %></h3>
                  <p class="course-progress-author">By <%= course.instructor %></p>
                </div>
                <span class="progress-badge"><%= course.progress %>% Complete</span>
              </div>
              <div class="progress-bar-wrapper">
                <div class="progress-bar" data-width="<%= course.progress %>"></div>
              </div>
              <a href="/courses/<%= course._id %>" class="btn-continue">Continue Learning</a>
            </div>
          </div>
          <% }); %>
          </div>
        
          <!-- Action Buttons -->
          <div class="courses-actions">
            <a href="/courses/all-courses" class="btn-explore">
              <i class="fa-solid fa-book-open"></i>
              Explore More Courses
            </a>
          </div>
        </section>

        <!-- Upcoming Challenges -->
        <section class="section-block">
          <div class="section-header">
            <h2 class="section-title">Upcoming Challenges</h2>
            <a href="/coding-challenges" class="section-link">View All →</a>
          </div>
          <div class="challenges-grid">
              <% challenges.forEach(function(challenge) { %>
            <div class="challenge-card">
              <div class="challenge-card-top">
                <span class="challenge-badge challenge-badge--<%= challenge.difficulty.toLowerCase() %>"><%= challenge.difficulty %></span>
                <span class="challenge-pts">
                  <i class="fa-solid fa-bolt-lightning"></i>
                  <%= challenge.points %> pts
                </span>
              </div>
              <h3 class="challenge-title"><%= challenge.title %></h3>
              <p class="challenge-due">
                <i class="fa-regular fa-clock"></i>
                Due in <%= challenge.dueInDays %> days
              </p>
            </div>
              <% }); %>
          </div>
        </section>

      </div>

      <!-- Right Column — Leaderboard -->
      <aside class="page-right">
        <div class="leaderboard-card">
          <div class="leaderboard-header">
            <h2 class="leaderboard-title">Leaderboard</h2>
            <a href="/student/leaderboard" class="leaderboard-link">View Full</a>
          </div>
          <div class="leaderboard-list">

           <% leaderboard.forEach(function(entry, index) { %>
            <div class="lb-item<%= index === 0 ? ' lb-item--first' : '' %>">
            <div class="lb-rank lb-rank--<%= entry.rank %>"><%= entry.rank %></div>
            <img src="<%= entry.avatar %>" alt="avatar" class="lb-avatar" />
              <div class="lb-info">
                <div class="lb-name"><%= entry.name %></div>
                <div class="lb-pts"><%= entry.points.toLocaleString() %> pts</div>
              </div>
             <% if (entry.rank === 1) { %>
                  <i class="fa-solid fa-trophy lb-trophy"></i>
                <% } else if (entry.rank === 2) { %>
                  <i class="fa-solid fa-trophy lb-trophy lb-trophy--silver"></i>
                <% } else if (entry.rank === 3) { %>
                  <i class="fa-solid fa-trophy lb-trophy lb-trophy--bronze"></i>
                 <% } %>
                  </div>       
                  <% }); %>
                  </div>
          </div>
        </div>
      </aside>

    </div>
  </main>

  <script src="/js/dashboards.js"></script>
  <script src="/js/main-navbar.js"></script>
</body>
</html>
