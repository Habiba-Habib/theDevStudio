<!DOCTYPE html>
<html lang="<%= locale || 'en' %>" dir="<%= isRTL ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/png" href="/images/favicon.png?v=2" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TheDevStudio - <%= __("courses.pageTitle") %></title>

<link rel="stylesheet" href="/css/base.css" />
<link rel="stylesheet" href="/css/all-courses.css" />
<link rel="stylesheet" href="/css/footer.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
<%- include('../partials/navbar') %>
  <main class="main-content">

    <section class="hero-section">
      <h1 class="hero-title"><%= __("courses.heroTitle") %></h1>
      <p class="hero-subtitle">
        <%= __("courses.heroSubtitle", { count: courses.length }) %>
      </p>
    </section>

    <section class="search-filter-section">
      <div class="search-bar-wrapper">
        <span class="search-icon">
          <i class="fa-solid fa-magnifying-glass"></i>
        </span>
        <input type="text" id="searchInput" class="search-input" placeholder="<%= __('courses.searchPlaceholder') %>" />
      </div>
    </section>

    <section class="filter-section">
      <div class="filter-row" id="categoryPills">
        <button class="filter-btn filter-btn-category active" data-category="all"><%= __("labels.all") %></button>
        <button class="filter-btn filter-btn-category" data-category="Web Development"><%= __("categories.webDevelopment") %></button>
        <button class="filter-btn filter-btn-category" data-category="Data Science"><%= __("categories.dataScience") %></button>
        <button class="filter-btn filter-btn-category" data-category="Mobile Development"><%= __("categories.mobileDevelopment") %></button>
        <button class="filter-btn filter-btn-category" data-category="Design"><%= __("categories.design") %></button>
        <button class="filter-btn filter-btn-category" data-category="Machine Learning"><%= __("categories.machineLearning") %></button>
      </div>
      <div class="filter-row" id="levelPills">
        <button class="filter-btn filter-btn-level active" data-level="all"><%= __("labels.all") %></button>
        <button class="filter-btn filter-btn-level" data-level="Beginner"><%= __("levels.beginner") %></button>
        <button class="filter-btn filter-btn-level" data-level="Intermediate"><%= __("levels.intermediate") %></button>
        <button class="filter-btn filter-btn-level" data-level="Advanced"><%= __("levels.advanced") %></button>
      </div>
    </section>

    <p class="showing-count" id="showingCount">Showing <%= courses.length %> courses</p>

    <section class="course-grid">

      <!-- Card -->
     <% courses.forEach(function(course) {
 const isOwn = course.isOwn;
%>
<article class="course-card <%= isOwn ? 'course-card--own' : '' %>" data-category="<%= course.category %>" data-level="<%= course.level %>">

  <% if (isOwn) { %>
    <div class="card-own-ribbon">
      <i class="fa-solid fa-graduation-cap"></i> <%= __("status.yourCourse") %>
    </div>
  <% } %>
  <% if (course.isEnrolled) { %>
  <div class="card-own-ribbon">
    <i class="fa-solid fa-check"></i> <%= __("status.enrolled") %>
  </div>
<% } %>
<% if (course.hasCertificate) { %>
  <div class="card-certificate-ribbon">
    <i class="fa-solid fa-certificate"></i> <%= __("status.certificateEarned") %>
  </div>
<% } %>


  <div class="card-image-wrapper">
    <img src="<%= course.thumbnail %>" alt="<%= course.title %>" class="card-image" />
    <span class="badge badge-<%= course.level.toLowerCase() %>"><%= course.level %></span>
  </div>



        <div class="card-body">
          <div class="card-meta">
            <span class="card-category"><%= course.category %></span>
            <span class="card-dot">•</span>
           <span class="card-hours"><%= course.duration || "0 hours" %> </span>
             </div>
          <h2 class="card-title"><%= course.title %></h2>
          <p class="card-desc"><%= course.shortDescription %></p>
          <p class="card-author">
            <%= __("labels.by") %> <%= course.instructor?.name || __("courses.unknownInstructor") %>
          </p>
          <div class="card-stats">
            <span class="card-rating">
              <i class="fa-solid fa-star"></i>
              <%= course.rating %> <span class="rating-count">(<%= (course.students?.length || 0).toLocaleString() %>)</span>
            </span>
            <span class="card-students">
              <i class="fa-solid fa-users"></i>
              <%= (course.students?.length || 0).toLocaleString() %>
            </span>
          </div>
          <div class="card-footer">
           <span class="card-price">$<%= course.price %></span>
             <% if (course.isEnrolled) { %>
            <a href="/student/my-courses" class="btn-view-details"><%= __("buttons.continue") %></a>
          <% } else { %>
            <a href="/courses/<%= course._id %>" class="btn-view-details"><%= __("buttons.viewDetails") %></a>
          <% } %>
          </div>
        </div>
      </article>
        <% }); %>
    </section>

    <p class="no-results hidden" id="noResults"><%= __("courses.noResults") %></p>

    <!-- Pagination -->
    <div class="pagination-wrap hidden" id="paginationWrap">
      <button class="page-btn" id="pagePrev" aria-label="Previous page">
        <i class="fa-solid fa-chevron-left"></i>
      </button>
      <div class="page-numbers" id="pageNumbers"></div>
      <button class="page-btn" id="pageNext" aria-label="Next page">
        <i class="fa-solid fa-chevron-right"></i>
      </button>
    </div>

  </main>
  <script>
  window.coursePageText = {
    showingCount: "<%= __('courses.showingCount') %>",
    showingCountSingle: "<%= __('courses.showingCountSingle') %>"
  };
</script>
  <script src="/js/all-courses.js"></script>
  <script src="/js/footer.js"></script>
</body>
</html>