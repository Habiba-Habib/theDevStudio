<!DOCTYPE html>
<html lang="<%= locale || 'en' %>" dir="<%= isRTL ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8"/>
  <link rel="icon" type="image/png" href="/images/favicon.png?v=2" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TheDevStudio | <%= __("challenges.pageTitle") %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link rel="stylesheet" href="/css/challengespage.css">
 <script>
  window.challengePageText = {
    showingCount: "<%= __('challenges.showingCount') %>",
    showingCountSingle: "<%= __('challenges.showingCountSingle') %>"
  };
</script>
  <script src="/js/challengescode.js" defer></script>
</head>
<body>
<%- include('../partials/navbar') %>
  <!-- HERO -->
  <header class="hero">
    <button class="btn-test-skills">
      <i class="fa-solid fa-trophy"></i> <%= __("challenges.heroBadge") %>
    </button>
    <h1><%= __("challenges.heroTitle") %></h1>
<p><%= __("challenges.heroSubtitle") %></p>
  </header>

  <!-- MAIN CONTENT -->
  <section class="challenges-section">

    <!-- STATS -->
    <div class="stats-container">
            <div class="stat-card">
        <i class="fa-solid fa-code icon-pink"></i>
        <h3><%= stats.totalChallenges %></h3>
        <p><%= __("challenges.totalChallenges") %></p>
      </div>
      <div class="stat-card">
        <i class="fa-solid fa-bolt icon-yellow"></i>
        <h3><%= stats.totalPoints %></h3>
        <p><%= __("challenges.totalPointsAvailable") %></p>
      </div>
      <div class="stat-card">
        <i class="fa-solid fa-trophy icon-teal"></i>
        <h3><%= stats.totalUsers %>+</h3>
        <p><%= __("challenges.activeCompetitors") %></p>
      </div>
    </div>

    <!-- FILTERS -->
    <div class="filters">
      <div class="filter-row">
        <span><%= __("challenges.difficulty") %></span>
        <div class="filter-btns" data-type="difficulty">
          <button class="active" data-value="all"><%= __("labels.all") %></button>
          <button data-value="easy"><%= __("difficulty.easy") %></button>
          <button data-value="medium"><%= __("difficulty.medium") %></button>
          <button data-value="hard"><%= __("difficulty.hard") %></button>
        </div>
      </div>
      <div class="filter-row">
        <span><%= __("challenges.category") %></span>
        <div class="filter-btns" data-type="category">
          <button class="active" data-value="all"><%= __("labels.all") %></button>

          <% [...new Set(challenges.map(c => c.category).filter(Boolean))].forEach(category => { %>
            <button data-value="<%= category.toLowerCase() %>"><%= category %></button>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- RESULTS COUNT -->
    <p id="results-count">
  <%= __("challenges.showingCount", { count: challenges.length }) %>
</p>

<div id="challenges-grid" class="challenges-grid">
  <% challenges.forEach(challenge => { %>
    <div class="challenge-card <%= (challenge.difficulty || '').toLowerCase() %>"
         data-difficulty="<%= (challenge.difficulty || '').toLowerCase() %>"
         data-category="<%= (challenge.category || '').toLowerCase() %>">

      <div class="card-header">
        <span class="badge badge-<%= (challenge.difficulty || '').toLowerCase() %>">
          <%= __("difficulty." + (challenge.difficulty || "").toLowerCase()) %>
        </span>
        <span class="card-points"><i class="fa-solid fa-bolt icon-yellow "></i> <%= challenge.points %> <%= __("challenges.points") %></span>
      </div>

      <h3 class="card-title"><%= challenge.title %></h3>
      <p class="card-summary"><%= challenge.description %></p>

      <div class="card-footer">
        <span class="card-category"><%= challenge.category %></span>
        <a href="/challenges/<%= challenge._id %>" class="btn-view">
          <%= __("buttons.viewChallenge") %>
        </a>
      </div>

    </div>
  <% }) %>
</div>

    <!-- Pagination -->
    <div class="pagination-wrap hidden" id="paginationWrap">
      <button class="page-btn" id="pagePrev" aria-label="Previous page">
        <i class="fa-solid fa-chevron-left"></i>
      </button>
      <div class="page-numbers" id="pageNumbers"></div>
      <button class="page-btn" id="pageNext" aria-label="Next page">
        <i class="fa-solid fa-chevron-right"></i>
      </button>
    </div>

  </section>

 
</body>
</html>