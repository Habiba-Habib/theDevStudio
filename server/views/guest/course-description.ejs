<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title><%= course.title %> – Course Description</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/course-description-css.css">
 
</head>

<body>
<%- include('../partials/navbar') %>
<div class="page-wrapper">

  <!-- LEFT -->
  <div class="left-col">

    <!-- BADGES -->
    <div class="badges">
      <span class="badge badge-frosted-blue"><%= course.category %></span>
      <span class="badge badge-Dragonfruit"><%= course.level %></span>
    </div>

    <!-- TITLE -->
    <h1 class="course-title"><%= course.title %></h1>

    <p class="course-description">
      <%= course.shortDescription %>
    </p>

    <!-- META -->
    <div class="meta-row">
      <span class="rating">
        <i class="fa-solid fa-star" style="color: rgb(255, 212, 59);"></i>
        <%= course.rating || 4.8 %>
        <span class="rating-count">(<%= course.students?.length || 0 %> students)</span>
      </span>

      <span class="meta-item">
        <i class="fa-regular fa-clock"></i> <%= course.duration || "40 hours" %>
      </span>

      <span class="meta-item">
        <i class="fa-solid fa-people-group"></i>
        <%= course.students?.length || 0 %> enrolled
      </span>
    </div>

    <!-- INSTRUCTOR -->
    <div class="Instructor">
      <div class="avatar">
        <img src="<%= course.instructor?.avatar || '/images/default-avatar.png' %>" alt="Instructor">
      </div>
      <div>
        <div class="title">Instructor</div>
        <div class="Instrutor-Name">
          <%= course.instructor?.name || "Unknown Instructor" %>
        </div>
      </div>
    </div>

    <hr class="horizontal-strip">

    <!-- IMAGE -->
    <img class="preview-image" src="<%= course.thumbnail %>" alt="Course Preview">

    <!-- WHAT YOU'LL LEARN -->
    <div class="learn-box">
      <h3 class="learn-title">What you'll learn</h3>

      <div class="learn-grid">
        <% course.learningOutcomes.forEach(outcome => { %>
          <div class="learn-item">
            <span class="check">✔</span>
            <%= outcome %>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- CURRICULUM -->
    <h3 class="learn-title" id="curriculum">Course Curriculum</h3>

    <% course.sections.forEach(section => { %>
      <div class="learn-box">

        <div class="learn-box-line1">
          <span class="course-c-title"><%= section.title %></span>
          <span class="lessons"><%= section.lessons.length %> lessons</span>
        </div>

        <div class="learn-list">
          <% section.lessons.forEach(lesson => { %>
            <div class="learn-lesson">
              <div class="play-button">▷</div>
            <%= lesson.title %>
            </div>
          <% }) %>
        </div>

      </div>
    <% }) %>

<h3 class="learn-title">Student Reviews</h3>
<div class="learn-box" style="text-align: center; padding: 32px; color: var(--text-muted);">
  <i class="fa-regular fa-star" style="font-size: 1.5rem; margin-bottom: 8px; display: block;"></i>
  No reviews yet. Be the first to review this course.
</div>


  </div>

  <!-- RIGHT SIDEBAR -->
  <div class="sidebar">

    <div class="pricing-card">

      <div class="pricing-top">
<% if (isOwner) { %>
  <div class="owner-top">
    <div class="owner-icon">
      <i class="fa-solid fa-graduation-cap"></i>
    </div>
    <h3 class="owner-title">Your Course</h3>
    <p class="owner-desc">Edit content, manage students, and track performance.</p>
  </div>
  <a href="/instructor/courses/<%= course._id %>/edit" class="btn-enroll">
    <i class="fa-solid fa-pen-to-square"></i> Edit Course
  </a>
  <a href="/student/course/<%= course._id %>/learn" class="btn-enroll" style="margin-top: 10px; background: transparent; border: 2px solid var(--pink, #FF40A0); color: var(--pink, #FF40A0);">
    <i class="fa-solid fa-circle-play"></i> View Course Player
  </a>






<% }else if (!isEnrolled) { %>
          <div class="price">$<%= course.price %></div>
          <div class="price-note">One-time payment • Full lifetime access</div>
          <a href="/student/payment/<%= course._id %>" class="btn-enroll">
            Enroll
          </a>
        <% } else { %>
          <div class="enrolled-badge">Enrolled</div>
          <div class="price-note">You have lifetime access to this course</div>
          <div class="enroll-progress-wrap">
            <div class="enroll-progress-label">
              <span>Your progress</span>
              <span><%= progress %>%</span>
            </div>
            <div class="enroll-progress-bar">
              <div class="enroll-progress-fill" data-progress="<%= progress %>"></div>
            </div>
          </div>
          <a href="/student/course/<%= course._id %>/learn" class="btn-enroll">Continue Learning</a>
        <% } %>
      </div>

      <hr class="pricing-divider">

      <div class="pricing-features">

        <div class="feature-item">
          <div class="feature-icon"><i class="fa-regular fa-clock"></i></div>
          <div>
            <div class="feature-title"><%= course.duration || "40 hours" %></div>
            <div class="feature-sub">Total duration</div>
          </div>
        </div>

        <div class="feature-item">
          <div class="feature-icon"><i class="fa-solid fa-signal"></i></div>
          <div>
            <div class="feature-title"><%= course.level %></div>
            <div class="feature-sub">Skill level</div>
          </div>
        </div>

        <div class="feature-item">
          <div class="feature-icon"><i class="fa-solid fa-book-open"></i></div>
          <div>
            <div class="feature-title"><%= course.sections.length %> Sections</div>
            <div class="feature-sub">Course modules</div>
          </div>
        </div>

      </div>

    </div>

  </div>

</div>

<script>
  document.querySelectorAll('.enroll-progress-fill[data-progress]').forEach((el) => {
    const value = Number(el.getAttribute('data-progress'));
    el.style.width = (Number.isFinite(value) ? value : 0) + '%';
  });
</script>

</body>
</html>