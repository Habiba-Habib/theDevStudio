<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof user !== "undefined" && user ? user.name : "User" %> - Become an Instructor</title>
  <link rel="stylesheet" href="/css/become-instructor3.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>

  <main class="main-content">


    <section class="hero-section">
      <div class="hero-icon">
        <i class="fa-solid fa-graduation-cap"></i>
      </div>
      <h1 class="hero-title">Become an Instructor</h1>
      <p class="hero-subtitle">Complete your verification to start publishing courses and teaching students on The Dev Studio</p>
    </section>

   
    <div class="stepper">
      <div class="step completed" id="step1">
        <div class="step-circle"><i class="fa-solid fa-user"></i></div>
        <span class="step-label">Personal Info</span>
      </div>
      <div class="step-line completed"></div>
      <div class="step completed" id="step2">
        <div class="step-circle"><i class="fa-solid fa-file-lines"></i></div>
        <span class="step-label">Documents</span>
      </div>
      <div class="step-line active"></div>
      <div class="step active" id="step3">
        <div class="step-circle"><i class="fa-solid fa-circle-check"></i></div>
        <span class="step-label">Review &amp; Submit</span>
      </div>
    </div>

    <div class="info-banner">
      <div class="info-icon">
        <i class="fa-regular fa-clock"></i>
      </div>
      <div class="info-body">
        <div class="info-header">
          <h3 class="info-title">Verification Process</h3>
        </div>
        <ul class="info-list">
          <li><i class="fa-regular fa-circle-check check-icon"></i> Application review typically takes 24–72 hours</li>
          <li><i class="fa-regular fa-circle-check check-icon"></i> Admin approval is required before accessing instructor features</li>
          <li><i class="fa-regular fa-circle-check check-icon"></i> You'll receive an email notification once your application is reviewed</li>
          <li><i class="fa-regular fa-circle-check check-icon"></i> Instructor dashboard will unlock after approval</li>
        </ul>
      </div>
    </div>

   
    <div class="card" id="summaryCard">
      <h2 class="card-title">Application Summary</h2>
      <div class="summary-table">

        <div class="summary-row">
          <span class="summary-label">Full Name</span>
          <span class="summary-value" id="sumFullName"><%= application.fullName || user?.name || '—' %></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">Professional Title</span>
          <span class="summary-value" id="sumTitle"><%= application.jobTitle || '—' %></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">Expertise</span>
          <span class="summary-value" id="sumExpertise"><%= application.experience || '—' %></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">Experience</span>
          <span class="summary-value" id="sumExperience"><%= application.experience || '—' %></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">Categories</span>
          <span class="summary-value" id="sumCategories"><%= application.categories || 'None selected' %></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">CV Upload</span>
                    <span class="summary-value" id="sumCV">
            <% if (verification.cvUrl) { %>
              <i class="fa-solid fa-circle-check"></i> Uploaded
            <% } else { %>
              <i class="fa-solid fa-circle-exclamation"></i> Not uploaded
            <% } %>
          </span>
        </div>
        <div class="summary-row no-border">
          <span class="summary-label">Certificate</span>
              <span class="summary-value" id="sumCert">
            <% if (verification.certificateUrl) { %>
              <i class="fa-solid fa-circle-check"></i> Uploaded
            <% } else { %>
              <i class="fa-solid fa-circle-exclamation"></i> Not uploaded
            <% } %>
          </span>
        </div>

      </div>
    </div>

    
        <form id="verificationForm" action="/become-instructor/step3" method="POST">

    <div class="card" id="agreementCard">
      <h2 class="card-title">Agreement</h2>

      <label class="checkbox-row">
        <input type="checkbox" id="chkAccurate" class="checkbox-input" />
        <span class="checkbox-box"></span>
        <span class="checkbox-text">
          <strong>I confirm all submitted information is accurate</strong>
          <span class="checkbox-hint">I understand that providing false information may result in account suspension</span>
        </span>
      </label>

      <label class="checkbox-row">
        <input type="checkbox" id="chkPolicies" class="checkbox-input" />
        <span class="checkbox-box"></span>
        <span class="checkbox-text">
          <strong>I agree to instructor platform policies</strong>
          <span class="checkbox-hint">Including content guidelines, student interaction policies, and payment terms</span>
        </span>
      </label>
    </div>

    <div class="actions">
      <a href="/become-instructor/step2" class="btn-back">Back</a>
      <button type="submit" class="btn-submit" id="btnSubmit">Submit Verification</button>
    </div>

    </form>

  </main>

  <script src="/js/become-instructor3.js"></script>
</body>
</html>