<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Become an Instructor – TheDevStudio</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/become-instructor-wizard.css" />

</head>
<body>
<%- include('../partials/navbar') %>
<main class="instructor-wizard main-content">

   
    <section class="hero-section">
      <div class="hero-icon">
        <i class="fa-solid fa-graduation-cap"></i>
      </div>
      <h1 class="hero-title">Become an Instructor</h1>
      <p class="hero-subtitle">Complete your verification to start publishing courses and teaching students on The Dev Studio</p>
    </section>

    
    <div class="stepper">
      <div class="step completed" id="step1">
        <div class="step-circle"><i class="fa-solid fa-user"></i></div>
        <span class="step-label">Personal Info</span>
      </div>
      <div class="step-line active"></div>
      <div class="step active" id="step2">
        <div class="step-circle"><i class="fa-solid fa-file-lines"></i></div>
        <span class="step-label">Documents</span>
      </div>
      <div class="step-line"></div>
      <div class="step" id="step3">
        <div class="step-circle"><i class="fa-solid fa-check"></i></div>
        <span class="step-label">Review &amp; Submit</span>
      </div>
    </div>

   
   <form class="card" id="pageDocuments" action="/become-instructor/step2" method="POST" enctype="multipart/form-data">

  <div class="form-group">
    <label class="field-label">Upload CV / Resume <span class="required">*</span></label>
    <div class="upload-zone" id="cvZone" data-input="cvInput">
      <input type="file" id="cvInput" name="cv" class="file-input" accept=".pdf,.doc,.docx" />
      <div class="upload-content" id="cvContent">
        <i class="fa-solid fa-arrow-up-from-bracket upload-icon"></i>
        <p class="upload-title">Click to upload or drag and drop</p>
        <p class="upload-hint">PDF, DOC, DOCX (Max 10MB)</p>
      </div>
      <div class="upload-preview hidden" id="cvPreview">
        <i class="fa-solid fa-file-lines file-icon"></i>
        <span class="file-name" id="cvFileName"></span>
        <button type="button" class="remove-file" id="cvRemove" title="Remove">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
    </div>
  </div>

  <div class="form-group">
    <label class="field-label">Professional Verification Document <span class="required">*</span></label>
    <p class="field-hint">Degree certificate, teaching certificate, or industry certification</p>
    <div class="upload-zone" id="certZone" data-input="certInput">
      <input type="file" id="certInput" name="certificate" class="file-input" accept=".pdf,.jpg,.jpeg,.png" />
      <div class="upload-content" id="certContent">
        <i class="fa-solid fa-award upload-icon"></i>
        <p class="upload-title">Click to upload or drag and drop</p>
        <p class="upload-hint">PDF, JPG, PNG (Max 10MB)</p>
      </div>
      <div class="upload-preview hidden" id="certPreview">
        <i class="fa-solid fa-file-lines file-icon"></i>
        <span class="file-name" id="certFileName"></span>
        <button type="button" class="remove-file" id="certRemove" title="Remove">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
    </div>
  </div>

  <div class="form-group">
    <label class="field-label">Professional Links</label>
    <p class="field-hint">Optional but recommended</p>

    <div class="link-fields">
      <div class="link-field">
        <label class="link-label">LinkedIn Profile</label>
        <div class="input-wrapper">
          <i class="fa-solid fa-link input-icon"></i>
          <input type="url" name="linkedinUrl" class="text-input" placeholder="https://linkedin.com/in/yourprofile" />
        </div>
      </div>

      <div class="link-field">
        <label class="link-label">Portfolio Link</label>
        <div class="input-wrapper">
          <i class="fa-solid fa-link input-icon"></i>
          <input type="url" name="portfolioUrl" class="text-input" placeholder="https://yourportfolio.com" />
        </div>
      </div>

      <div class="link-field">
        <label class="link-label">Personal Website</label>
        <div class="input-wrapper">
          <i class="fa-solid fa-link input-icon"></i>
          <input type="url" name="websiteUrl" class="text-input" placeholder="https://yourwebsite.com" />
        </div>
      </div>
    </div>
  </div>

  <div class="actions">
    <a href="/become-instructor" class="btn-back">
      <i class="fa-solid fa-arrow-left"></i> Back
    </a>
    <button type="submit" class="btn-continue" id="btnContinue">
      Continue to Review <i class="fa-solid fa-arrow-right"></i>
    </button>
  </div>

</form>
  </main>

  <script src="/js/become-instructor2.js"></script>
</body>
</html>



 
 