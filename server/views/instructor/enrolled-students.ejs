<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <link rel="icon" type="image/png" href="/images/favicon.png?v=2" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Enrolled Students – <%= course.title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/enrolled-students.css"/>
</head>
<body>

  <%- include('../partials/navbar') %>

  <a href="/instructor/dashboard" class="back-link">
    <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
  </a>

  <!-- PAGE HEADER -->
  <div class="page-header">
    <h1>Enrolled Students</h1>
    <p><span><%= course.title %></span> • <%= students.length %> students</p>
  </div>

  <!-- STAT CARDS -->
  <div class="stats-grid">

    <div class="stat-card">
      <div class="stat-icon pink">
        <i class="fa-solid fa-arrow-trend-up"></i>
      </div>
      <div class="stat-info">
        <h3><%= avgProgress %>%</h3>
        <p>Average Progress</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon teal">
        <i class="fa-regular fa-clock"></i>
      </div>
      <div class="stat-info">
        <h3><%= activeToday %></h3>
        <p>Active Today</p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon yellow">
        <i class="fa-solid fa-arrow-trend-up"></i>
      </div>
      <div class="stat-info">
        <h3><%= nearCompletion %></h3>
        <p>Near Completion</p>
      </div>
    </div>

  </div>

  <!-- SEARCH -->
  <div class="search-bar">
    <i class="fa-solid fa-magnifying-glass"></i>
    <input
      type="text"
      id="searchInput"
      placeholder="Search students..."
    />
  </div>

  <!-- RESULTS COUNT -->
  <p class="results-count" id="resultsCount">
    Showing <%= students.length %> students
  </p>

  <!-- STUDENT CARDS -->
  <div class="students-list" id="studentsList">

    <% if (students.length === 0) { %>
      <div class="empty-state">
        <i class="fa-solid fa-users-slash"></i>
        <p>No students enrolled in this course yet.</p>
      </div>
    <% } %>

    <% students.forEach(student => { %>
      <div class="student-card"
           data-name="<%= student.name.toLowerCase() %>"
           data-email="<%= student.email.toLowerCase() %>">

        <div class="student-top">
          <div class="student-info">
            <img
              src="/images/avatars/<%= student.avatar %>"
              alt="<%= student.name %>"
              class="student-avatar"
              onerror="this.src='/images/avatars/avatar1g.png'"
            />
            <div>
              <div class="student-name"><%= student.name %></div>
              <div class="student-email"><%= student.email %></div>
            </div>
          </div>

          <a href="mailto:<%= student.email %>" class="contact-btn">
            <i class="fa-regular fa-envelope"></i> Contact
          </a>
        </div>

        <div class="progress-label">
          <span>Progress</span>
          <span><%= student.progress %>%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill" data-progress="<%= student.progress %>"></div>
        </div>

        <div class="student-meta">
          <span>
            <i class="fa-regular fa-clock"></i>
            Last active: <%= student.lastActive %>
          </span>
          <span>
            <i class="fa-regular fa-calendar"></i>
            Enrolled: <%= new Date(student.enrolledAt).toLocaleDateString() %>
          </span>
        </div>

      </div>
    <% }) %>

  </div>

  <script src="/js/instructor/enrolled-students.js"></script>

  <!-- ── ASSIGNMENT SUBMISSIONS SECTION ── -->
  <div style="max-width:900px; margin: 32px auto 60px; padding: 0 20px;">
    <h2 style="font-size:18px; font-weight:700; color:var(--text-white); margin-bottom:16px;">
      <i class="fa-solid fa-inbox" style="color:var(--pink); margin-right:8px;"></i>
      Assignment Submissions
      <% if (submissions && submissions.length > 0) { %>
        <span style="font-size:13px; font-weight:600; background:rgba(255,64,160,0.15); color:var(--pink); border-radius:20px; padding:3px 10px; margin-left:8px;"><%= submissions.length %></span>
      <% } %>
    </h2>

    <% if (!submissions || submissions.length === 0) { %>
      <div style="background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:36px 20px; text-align:center; color:var(--text-muted);">
        <i class="fa-regular fa-folder-open" style="font-size:2rem; margin-bottom:10px; display:block; opacity:0.4;"></i>
        <p style="font-size:14px;">No submissions yet. Students will appear here once they submit their assignments.</p>
      </div>
    <% } else { %>
      <div style="display:flex; flex-direction:column; gap:10px;">
        <% submissions.forEach(sub => {
             const student = students.find(s => s._id.toString() === sub.studentId);
        %>
          <div style="display:flex; align-items:center; gap:14px; background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:14px 18px;">
            <img
              src="/images/avatars/<%= student?.avatar || 'avatar1g.png' %>"
              alt="<%= student?.name %>"
              style="width:40px; height:40px; border-radius:50%; object-fit:cover; flex-shrink:0;"
              onerror="this.src='/images/avatars/avatar1g.png'"
            />
            <div style="flex:1; min-width:0;">
              <div style="font-size:14px; font-weight:700; color:var(--text-white);"><%= student?.name || 'Unknown Student' %></div>
              <div style="font-size:12px; color:var(--text-muted); margin-top:2px;">
                <i class="fa-solid fa-book-open" style="margin-right:4px;"></i><%= sub.lessonTitle %>
                &nbsp;·&nbsp;
                <i class="fa-regular fa-calendar" style="margin-right:4px;"></i><%= new Date(sub.submittedAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %>
              </div>
            </div>
            <div style="font-size:13px; color:var(--text-muted); min-width:0; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
              <i class="fa-solid fa-file" style="margin-right:5px;"></i><%= sub.fileName %>
            </div>
            <a href="/instructor/submission-download?url=<%= encodeURIComponent(sub.fileUrl) %>&name=<%= encodeURIComponent(sub.fileName) %>"
               style="display:inline-flex; align-items:center; gap:7px; padding:8px 16px; background:linear-gradient(90deg,var(--pink),var(--pink-light)); color:#fff; border-radius:8px; font-size:13px; font-weight:600; text-decoration:none; flex-shrink:0;">
              <i class="fa-solid fa-download"></i> Download
            </a>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

</body>
</html>