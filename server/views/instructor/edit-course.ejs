<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Edit Course - <%= course.title %></title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/edit-course.css" />
</head>

<body>
<%- include('../partials/navbar') %>

<%
  const sections = course.sections && course.sections.length
    ? course.sections
    : [{ title: '', lessons: [{ title: '', videoUrl: '', duration: '' }] }];
%>

<div class="edit-course-shell">

  <header class="edit-course-header">
    <div>
      <a class="back-link" href="/instructor/dashboard">
        <i class="fa-solid fa-arrow-left"></i>
        Dashboard
      </a>

      <h1>Edit Course</h1>
      <p>Update course details, curriculum, videos, pricing, and thumbnail.</p>
    </div>

    <div class="header-actions">
      <a href="/courses/<%= course._id %>" class="btn-secondary">View Course</a>
      <button type="submit" form="editCourseForm" class="btn-primary">Save Changes</button>
    </div>
  </header>

  <form
    id="editCourseForm"
    action="/instructor/courses/<%= course._id %>/edit"
    method="POST"
    enctype="multipart/form-data"
  >
    <div class="edit-course-grid">

      <main class="edit-main">

        <section class="edit-card">
          <h2 class="card-title">Basic Information</h2>

          <div class="form-group">
            <label class="form-label">Course Title</label>
            <input
              type="text"
              class="form-input"
              name="title"
              value="<%= course.title || '' %>"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label">Short Description</label>
            <input
              type="text"
              class="form-input"
              name="shortDescription"
              value="<%= course.shortDescription || '' %>"
            />
          </div>

          <div class="form-group">
            <label class="form-label">Full Description</label>
            <textarea class="form-input" name="fullDescription"><%= course.fullDescription || '' %></textarea>
          </div>

          <div class="two-col">
            <div class="form-group">
              <label class="form-label">Category</label>
              <select class="form-input" name="category" required>
                <option value="Web Development" <%= course.category === 'Web Development' ? 'selected' : '' %>>Web Development</option>
                <option value="Data Science" <%= course.category === 'Data Science' ? 'selected' : '' %>>Data Science</option>
                <option value="Design" <%= course.category === 'Design' ? 'selected' : '' %>>Design</option>
                <option value="Business" <%= course.category === 'Business' ? 'selected' : '' %>>Business</option>
                <option value="Mobile Development" <%= course.category === 'Mobile Development' ? 'selected' : '' %>>Mobile Development</option>
                <option value="Machine Learning" <%= course.category === 'Machine Learning' ? 'selected' : '' %>>Machine Learning</option>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">Level</label>
              <select class="form-input" name="level" required>
                <option value="Beginner" <%= course.level === 'Beginner' ? 'selected' : '' %>>Beginner</option>
                <option value="Intermediate" <%= course.level === 'Intermediate' ? 'selected' : '' %>>Intermediate</option>
                <option value="Advanced" <%= course.level === 'Advanced' ? 'selected' : '' %>>Advanced</option>
              </select>
            </div>
          </div>
        </section>

        <section class="edit-card">
          <h2 class="card-title">Learning Outcomes</h2>

          <div id="outcomes-list">
            <% if (course.learningOutcomes && course.learningOutcomes.length) { %>
              <% course.learningOutcomes.forEach((outcome) => { %>
                <div class="outcome-item">
                  <input
                    type="text"
                    class="form-input"
                    name="outcomes[]"
                    value="<%= outcome %>"
                    placeholder="e.g. Build responsive websites"
                  />
                  <button type="button" class="btn-icon btn-remove">
                    <i class="fa-solid fa-xmark"></i>
                  </button>
                </div>
              <% }) %>
            <% } else { %>
              <div class="outcome-item">
                <input
                  type="text"
                  class="form-input"
                  name="outcomes[]"
                  placeholder="e.g. Build responsive websites"
                />
                <button type="button" class="btn-icon btn-remove">
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
            <% } %>
          </div>

          <button type="button" id="add-outcome" class="btn-add">
            <i class="fa-solid fa-plus"></i>
            Add Outcome
          </button>
        </section>

        <section class="edit-card">
          <h2 class="card-title">Course Curriculum</h2>

          <div id="sections-list">
            <% sections.forEach((section, si) => { %>
              <div class="section-card">

                <div class="form-group">
                  <label class="form-label">Section Title</label>
                  <input
                    type="text"
                    class="form-input"
                    name="sections[<%= si %>][title]"
                    value="<%= section.title || '' %>"
                    placeholder="Section title"
                  />
                </div>

                <div class="lesson-container">
                  <%
                    const lessons = section.lessons && section.lessons.length
                      ? section.lessons
                      : [{ title: '', videoUrl: '', duration: '' }];
                  %>

                  <% lessons.forEach((lesson, li) => { %>
                    <div class="lesson-item">

                      <div class="lesson-row">
                        <input
                          type="text"
                          class="form-input"
                          name="sections[<%= si %>][lessons][<%= li %>][title]"
                          value="<%= lesson.title || '' %>"
                          placeholder="Lesson title"
                        />

                        <button type="button" class="btn-icon btn-remove">
                          <i class="fa-solid fa-xmark"></i>
                        </button>
                      </div>

                      <div class="lesson-meta-grid">
                        <input
                          type="url"
                          class="form-input"
                          name="sections[<%= si %>][lessons][<%= li %>][videoUrl]"
                          value="<%= lesson.videoUrl || '' %>"
                          placeholder="Video URL"
                        />

                        <input
                          type="text"
                          class="form-input"
                          name="sections[<%= si %>][lessons][<%= li %>][duration]"
                          value="<%= lesson.duration || '' %>"
                          placeholder="Duration"
                        />
                      </div>

                    </div>
                  <% }) %>
                </div>

                <button type="button" class="btn-add">
                  <i class="fa-solid fa-plus"></i>
                  Add Lesson
                </button>

              </div>
            <% }) %>
          </div>

          <button type="button" id="add-section" class="btn-add-section">
            <i class="fa-solid fa-plus"></i>
            Add Section
          </button>
        </section>

      </main>

      <aside class="edit-sidebar">

        <section class="edit-card">
          <h2 class="card-title">Thumbnail</h2>

          <% if (course.thumbnail) { %>
            <img class="thumbnail-preview" src="<%= course.thumbnail %>" alt="Course thumbnail" />
          <% } %>

          <div class="upload-area" id="upload-area">
            <input
              type="file"
              id="file-input"
              name="thumbnail"
              accept="image/*"
              style="display:none"
            />

            <div class="upload-icon">
              <i class="fa-solid fa-arrow-up-from-bracket"></i>
            </div>

            <div class="upload-text">Click to upload thumbnail</div>
            <div class="upload-hint">PNG or JPG. Leave empty to keep current.</div>
          </div>
        </section>

        <section class="edit-card">
          <h2 class="card-title">Pricing</h2>

          <div class="form-group">
            <label class="form-label">Price ($)</label>
            <input
              type="number"
              class="form-input"
              name="price"
              value="<%= course.price || 0 %>"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label">Course Duration</label>
            <input
              type="text"
              class="form-input"
              name="duration"
              value="<%= course.duration || '' %>"
              placeholder="e.g. 40 hours"
            />
          </div>
        </section>

        <section class="edit-card">
          <button type="submit" class="btn-primary full-width">Save Changes</button>
          <a href="/courses/<%= course._id %>" class="btn-secondary full-width center">Cancel</a>
        </section>

      </aside>

    </div>
  </form>

</div>

<script src="/js/edit-course.js"></script>
</body>
</html>