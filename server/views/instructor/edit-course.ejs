<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Edit Course - <%= course.title %></title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="/css/edit-course.css?v=3" />

</head>

<body>
<%- include('../partials/navbar') %>

<%
  const sections = course.sections && course.sections.length
    ? course.sections
    : [{ title: '', lessons: [{ title: '', videoSource: 'url', videoUrl: '', videoFile: '', duration: '' }] }];
%>

<main class="main-content">
  <div class="edit-course-container">

    <div class="page-header">
      <a href="/instructor/dashboard" class="btn-back">
        <i class="fa-solid fa-arrow-left"></i>
        Back to Dashboard
      </a>

      <h1 class="page-title">Edit Course</h1>
      <p class="page-subtitle">Update course details, sections, lessons, videos, and pricing.</p>
    </div>

    <form
      id="editCourseForm"
      action="/instructor/courses/<%= course._id %>/edit"
      method="POST"
      enctype="multipart/form-data"
    >
      <div class="edit-course-grid">

        <div class="edit-course-main">

          <section class="edit-card">
            <div class="card-header">
              <h2 class="card-title">Course Overview</h2>
            </div>

            <div class="form-group">
              <label class="form-label">Course Title <span class="required">*</span></label>
              <input
                type="text"
                class="form-input"
                name="title"
                value="<%= course.title || '' %>"
                required
                placeholder="Enter course title"
              />
            </div>

            <div class="form-group">
              <label class="form-label">Short Description</label>
              <input
                type="text"
                class="form-input"
                name="shortDescription"
                value="<%= course.shortDescription || '' %>"
                placeholder="A brief summary for course cards"
              />
            </div>

            <div class="form-group">
              <label class="form-label">Full Description</label>
              <textarea
                class="form-input"
                name="fullDescription"
                rows="5"
                placeholder="Describe what students will learn"
              ><%= course.fullDescription || '' %></textarea>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Category <span class="required">*</span></label>
                <select class="form-input" name="category" required>
                  <option value="">Select category</option>
                  <option value="Web Development" <%= course.category === 'Web Development' ? 'selected' : '' %>>Web Development</option>
                  <option value="Data Science" <%= course.category === 'Data Science' ? 'selected' : '' %>>Data Science</option>
                  <option value="Design" <%= course.category === 'Design' ? 'selected' : '' %>>Design</option>
                  <option value="Business" <%= course.category === 'Business' ? 'selected' : '' %>>Business</option>
                  <option value="Mobile Development" <%= course.category === 'Mobile Development' ? 'selected' : '' %>>Mobile Development</option>
                  <option value="Machine Learning" <%= course.category === 'Machine Learning' ? 'selected' : '' %>>Machine Learning</option>
                </select>
              </div>

              <div class="form-group">
                <label class="form-label">Level <span class="required">*</span></label>
                <select class="form-input" name="level" required>
                  <option value="">Select level</option>
                  <option value="Beginner" <%= course.level === 'Beginner' ? 'selected' : '' %>>Beginner</option>
                  <option value="Intermediate" <%= course.level === 'Intermediate' ? 'selected' : '' %>>Intermediate</option>
                  <option value="Advanced" <%= course.level === 'Advanced' ? 'selected' : '' %>>Advanced</option>
                </select>
              </div>
            </div>
          </section>

          <section class="edit-card">
            <div class="card-header">
              <h2 class="card-title">Learning Outcomes</h2>
            </div>

            <div id="outcomes-list">
              <% if (course.learningOutcomes && course.learningOutcomes.length) { %>
                <% course.learningOutcomes.forEach((outcome) => { %>
                  <div class="outcome-item">
                    <input
                      type="text"
                      class="form-input"
                      name="outcomes[]"
                      value="<%= outcome %>"
                      placeholder="e.g. Build responsive websites"
                    />
                    <button type="button" class="btn-icon btn-remove" onclick="removeOutcome(this)">
                      <i class="fa-solid fa-xmark"></i>
                    </button>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="outcome-item">
                  <input
                    type="text"
                    class="form-input"
                    name="outcomes[]"
                    placeholder="e.g. Build responsive websites"
                  />
                  <button type="button" class="btn-icon btn-remove" onclick="removeOutcome(this)">
                    <i class="fa-solid fa-xmark"></i>
                  </button>
                </div>
              <% } %>
            </div>

            <button type="button" id="add-outcome" class="btn-add">
              <i class="fa-solid fa-plus"></i>
              Add Outcome
            </button>
          </section>

          <section class="edit-card">
            <div class="card-header">
              <h2 class="card-title">Course Content</h2>
            </div>

            <p class="section-help">
              Click a section to expand it, then edit lessons and video settings inside.
            </p>

            <div id="sections-container">
              <% sections.forEach((section, sectionIndex) => { %>
                <div class="section-card" data-section-index="<%= sectionIndex %>">

                  <div class="section-header-row">
                    <button type="button" class="btn-toggle-section collapsed" onclick="toggleSection(this)">
                      <i class="fa-solid fa-chevron-right"></i>
                    </button>

                    <input
                      type="text"
                      class="form-input section-title-input"
                      name="sections[<%= sectionIndex %>][title]"
                      value="<%= section.title || '' %>"
                      placeholder="Section title"
                    />

                    <button type="button" class="btn-icon btn-remove-section" onclick="removeSection(this)">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </div>

                  <div class="section-content collapsed">
                    <div class="lessons-container">
                      <%
                        const lessons = section.lessons && section.lessons.length
                          ? section.lessons
                          : [{ title: '', videoSource: 'url', videoUrl: '', videoFile: '', duration: '' }];
                      %>

                      <% lessons.forEach((lesson, lessonIndex) => { %>
                        <div class="lesson-item" data-lesson-index="<%= lessonIndex %>">

                          <div class="lesson-header">
                            <button type="button" class="btn-toggle-lesson collapsed" onclick="toggleLesson(this)">
                              <i class="fa-solid fa-chevron-right"></i>
                            </button>

                            <input
                              type="text"
                              class="form-input lesson-title-input"
                              name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][title]"
                              value="<%= lesson.title || '' %>"
                              placeholder="Lesson title"
                            />

                            <button type="button" class="btn-icon btn-remove-lesson" onclick="removeLesson(this)">
                              <i class="fa-solid fa-xmark"></i>
                            </button>
                          </div>

                          <div class="lesson-content collapsed">

<div class="lesson-subsection">
  <h4><i class="fa-solid fa-file-lines"></i> Documents</h4>
  
  <% if (lesson.resourceFile) { %>
    <!-- Show existing file with options -->
    <div class="existing-file-card">
      <div class="existing-file-info">
        <i class="fa-solid fa-file-pdf"></i>
        <span class="existing-file-name"><%= lesson.resourceFile.split('/').pop().split('?')[0] %></span>
      </div>
      <div class="existing-file-actions">
        <button type="button" class="btn-replace-file" onclick="replaceFile(this, 'resource', <%= sectionIndex %>, <%= lessonIndex %>)">
          <i class="fa-solid fa-repeat"></i> Replace
        </button>
        <button type="button" class="btn-delete-file" onclick="deleteFile(this, 'resource', <%= sectionIndex %>, <%= lessonIndex %>)">
          <i class="fa-solid fa-trash"></i> Delete
        </button>
      </div>
    </div>
    
    <!-- Hidden input to track deletion -->
    <input type="hidden" 
      name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][deleteResourceFile]" 
      value="false"
      class="delete-resource-flag"
    />
    
    <!-- File upload (hidden until replace is clicked) -->
    <div class="replace-file-zone hidden" data-type="resource-<%= sectionIndex %>-<%= lessonIndex %>">
      <input
        type="file"
        class="form-input"
        name="sections_<%= sectionIndex %>_lessons_<%= lessonIndex %>_resourceFile"
        accept=".pdf,.doc,.docx,.ppt,.pptx"
      />
      <p class="file-type-hint"><i class="fa-solid fa-circle-info"></i> Accepted: PDF, DOC, DOCX, PPT, PPTX</p>
      <button type="button" class="btn-cancel-replace" onclick="cancelReplace(this, 'resource', <%= sectionIndex %>, <%= lessonIndex %>)">
        <i class="fa-solid fa-xmark"></i> Cancel
      </button>
    </div>
  <% } else { %>
    <!-- No existing file - show upload input -->
    <input
      type="file"
      class="form-input"
      name="sections_<%= sectionIndex %>_lessons_<%= lessonIndex %>_resourceFile"
      accept=".pdf,.doc,.docx,.ppt,.pptx"
    />
    <p class="file-type-hint"><i class="fa-solid fa-circle-info"></i> Accepted: PDF, DOC, DOCX, PPT, PPTX</p>
  <% } %>
  
  <input type="hidden"
    name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][existingResourceFile]"
    value="<%= lesson.resourceFile || '' %>"
  />
</div>

<div class="lesson-subsection">
  <h4><i class="fa-solid fa-clipboard-list"></i> Assignment</h4>
  
  <% if (lesson.assignmentFile) { %>
    <!-- Show existing file with options -->
    <div class="existing-file-card">
      <div class="existing-file-info">
        <i class="fa-solid fa-file-lines"></i>
        <span class="existing-file-name"><%= lesson.assignmentFile.split('/').pop().split('?')[0] %></span>
      </div>
      <div class="existing-file-actions">
        <button type="button" class="btn-replace-file" onclick="replaceFile(this, 'assignment', <%= sectionIndex %>, <%= lessonIndex %>)">
          <i class="fa-solid fa-repeat"></i> Replace
        </button>
        <button type="button" class="btn-delete-file" onclick="deleteFile(this, 'assignment', <%= sectionIndex %>, <%= lessonIndex %>)">
          <i class="fa-solid fa-trash"></i> Delete
        </button>
      </div>
    </div>
    
    <!-- Hidden input to track deletion -->
    <input type="hidden" 
      name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][deleteAssignmentFile]" 
      value="false"
      class="delete-assignment-flag"
    />
    
    <!-- File upload (hidden until replace is clicked) -->
    <div class="replace-file-zone hidden" data-type="assignment-<%= sectionIndex %>-<%= lessonIndex %>">
      <input
        type="file"
        class="form-input"
        name="sections_<%= sectionIndex %>_lessons_<%= lessonIndex %>_assignmentFile"
        accept=".pdf,.doc,.docx,.ppt,.pptx"
      />
      <p class="file-type-hint"><i class="fa-solid fa-circle-info"></i> Accepted: PDF, DOC, DOCX, PPT, PPTX</p>
      <button type="button" class="btn-cancel-replace" onclick="cancelReplace(this, 'assignment', <%= sectionIndex %>, <%= lessonIndex %>)">
        <i class="fa-solid fa-xmark"></i> Cancel
      </button>
    </div>
  <% } else { %>
    <!-- No existing file - show upload input -->
    <input
      type="file"
      class="form-input"
      name="sections_<%= sectionIndex %>_lessons_<%= lessonIndex %>_assignmentFile"
      accept=".pdf,.doc,.docx,.ppt,.pptx"
    />
    <p class="file-type-hint"><i class="fa-solid fa-circle-info"></i> Accepted: PDF, DOC, DOCX, PPT, PPTX</p>
  <% } %>
  
  <input type="hidden"
    name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][existingAssignmentFile]"
    value="<%= lesson.assignmentFile || '' %>"
  />
</div>

<div class="lesson-subsection">
  <h4><i class="fa-solid fa-film"></i> Video</h4>
  
  <% if (lesson.videoFile || lesson.videoUrl) { %>
    <!-- Show existing video info -->
    <div class="existing-file-card">
      <div class="existing-file-info">
        <% if (lesson.videoSource === 'upload' && lesson.videoFile) { %>
          <i class="fa-solid fa-file-video"></i>
          <div>
            <span class="existing-file-name"><%= lesson.videoFile.split('/').pop().split('?')[0] %></span>
            <span class="existing-file-type">Uploaded Video</span>
          </div>
        <% } else if (lesson.videoUrl) { %>
          <i class="fa-brands fa-youtube"></i>
          <div>
            <span class="existing-file-name"><%= lesson.videoUrl.substring(0, 50) %><%= lesson.videoUrl.length > 50 ? '...' : '' %></span>
            <span class="existing-file-type">External Video URL</span>
          </div>
        <% } %>
      </div>
      <div class="existing-file-actions">
        <button type="button" class="btn-replace-file" onclick="replaceVideo(this, <%= sectionIndex %>, <%= lessonIndex %>)">
          <i class="fa-solid fa-repeat"></i> Replace
        </button>
        <button type="button" class="btn-delete-file" onclick="deleteVideo(this, <%= sectionIndex %>, <%= lessonIndex %>)">
          <i class="fa-solid fa-trash"></i> Delete
        </button>
      </div>
    </div>
    
    <!-- Hidden input to track deletion -->
    <input type="hidden" 
      name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][deleteVideo]" 
      value="false"
      class="delete-video-flag"
    />
    
    <!-- Video upload/URL zone (hidden until replace is clicked) -->
    <div class="replace-file-zone hidden" data-type="video-<%= sectionIndex %>-<%= lessonIndex %>">
      <div class="video-item">
        <label class="form-label" style="margin-bottom: 8px;">Video Source</label>
        <select
          class="form-input video-source"
          name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][videoSource]"
          onchange="toggleVideoSource(this)"
        >
          <option value="url">Type URL</option>
          <option value="upload">Upload File</option>
        </select>

        <div class="video-url-input">
          <input type="url" class="form-input"
            name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][videoUrl]"
            placeholder="YouTube, Vimeo, or direct video URL"
          />
        </div>

        <div class="video-file-input hidden">
          <input type="file" class="form-input"
            name="sections_<%= sectionIndex %>_lessons_<%= lessonIndex %>_videoFile"
            accept="video/*"
            onchange="extractVideoDuration(this)"
          />
          <p class="file-type-hint"><i class="fa-solid fa-circle-info"></i> Accepted: MP4, MOV, AVI, MKV, WebM</p>
        </div>
      </div>
      
      <button type="button" class="btn-cancel-replace" onclick="cancelReplaceVideo(this, <%= sectionIndex %>, <%= lessonIndex %>)">
        <i class="fa-solid fa-xmark"></i> Cancel
      </button>
    </div>
    
  <% } else { %>
    <!-- No existing video - show upload/URL input -->
    <div class="video-item">
      <select
        class="form-input video-source"
        name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][videoSource]"
        onchange="toggleVideoSource(this)"
      >
        <option value="url" <%= lesson.videoSource !== 'upload' ? 'selected' : '' %>>Type URL</option>
        <option value="upload" <%= lesson.videoSource === 'upload' ? 'selected' : '' %>>Upload File</option>
      </select>

      <div class="video-url-input <%= lesson.videoSource === 'upload' ? 'hidden' : '' %>">
        <input type="url" class="form-input"
          name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][videoUrl]"
          value="<%= lesson.videoUrl || '' %>"
          placeholder="YouTube, Vimeo, or direct video URL"
        />
      </div>

      <div class="video-file-input <%= lesson.videoSource === 'upload' ? '' : 'hidden' %>">
        <input type="file" class="form-input"
          name="sections_<%= sectionIndex %>_lessons_<%= lessonIndex %>_videoFile"
          accept="video/*"
          onchange="extractVideoDuration(this)"
        />
        <p class="file-type-hint"><i class="fa-solid fa-circle-info"></i> Accepted: MP4, MOV, AVI, MKV, WebM</p>
      </div>
    </div>
  <% } %>

  <input type="hidden"
    name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][existingVideoFile]"
    value="<%= lesson.videoFile || '' %>"
  />
  <input type="hidden"
    class="lesson-duration-hidden"
    name="sections[<%= sectionIndex %>][lessons][<%= lessonIndex %>][duration]"
    value="<%= lesson.duration || '' %>"
  />
</div>



                          </div>
                        </div>
                      <% }) %>
                    </div>

                    <button type="button" class="btn-add-lesson" onclick="addLesson(this)">
                      <i class="fa-solid fa-plus"></i>
                      Add Lesson
                    </button>
                  </div>
                </div>
              <% }) %>
            </div>

            <button type="button" id="add-section" class="btn-add-section">
              <i class="fa-solid fa-plus"></i>
              Add Section
            </button>
          </section>
        </div>

        <div class="edit-course-sidebar">

          <section class="edit-card sidebar-card">
            <div class="card-header">
              <h2 class="card-title"><i class="fa-solid fa-tag"></i> Pricing</h2>
            </div>

            <div class="form-group">
              <label class="form-label">Price ($) <span class="required">*</span></label>
         <input
              type="number"
              class="form-input"
              name="price"
              value="<%= course.price || 0 %>"
              min="0"
              step="0.01"
              required
              placeholder="0"
            />

            </div>

            <div class="form-group">
              <label class="form-label">Duration</label>
              <input
                type="text"
                class="form-input"
                name="duration"
                value="<%= course.duration || '' %>"
                placeholder="e.g. 40 hours"
              />
            </div>
          </section>
          <!-- Publish Status Card -->
      <section class="edit-card sidebar-card">
  <div class="card-header">
    <h2 class="card-title"><i class="fa-solid fa-square-share-nodes"></i> Course Status</h2>
  </div>
  <div class="form-group" style="margin-top: 12px; margin-bottom: 0;">
    <% 
      let statusText = 'Draft';
      let statusColor = 'var(--text-muted)';
      let statusIcon = 'fa-file';
      
      if (course.approvalStatus === 'pending') {
        statusText = 'Pending Admin Approval';
        statusColor = '#f59e0b';
        statusIcon = 'fa-clock';
      } else if (course.approvalStatus === 'rejected') {
        statusText = 'Rejected';
        statusColor = 'var(--pink)';
        statusIcon = 'fa-times-circle';
      } else if (course.approvalStatus === 'approved' && course.isPublished) {
        statusText = 'Published & Live';
        statusColor = '#10b981';
        statusIcon = 'fa-circle-check';
      }
    %>
    <div style="padding: 16px; background: rgba(255,255,255,0.03); border: 2px solid var(--border); border-radius: 12px; display: flex; align-items: center; gap: 12px;">
      <i class="fa-solid <%= statusIcon %>" style="font-size: 24px; color: <%= statusColor %>;"></i>
      <div>
        <div style="font-size: 14px; color: var(--text-muted);">Current Status</div>
        <div style="font-size: 16px; font-weight: 700; color: <%= statusColor %>;"><%= statusText %></div>
      </div>
    </div>
    
    <% if (course.approvalStatus === 'rejected' && course.rejectionReason) { %>
      <div style="margin-top: 12px; padding: 12px; background: rgba(255,64,160,0.1); border: 1px solid rgba(255,64,160,0.3); border-radius: 8px;">
        <div style="font-size: 12px; font-weight: 600; color: var(--pink); margin-bottom: 4px;">REJECTION REASON:</div>
        <div style="font-size: 14px; color: var(--text-body);"><%= course.rejectionReason %></div>
      </div>
    <% } %>
    
    <p style="margin-top: 12px; font-size: 13px; color: var(--text-muted); line-height: 1.6;">
      <i class="fa-solid fa-info-circle"></i> 
      Course status is managed by administrators. Check your dashboard for approval updates.
    </p>
  </div>
</section>


          <section class="edit-card sidebar-card">
            <div class="card-header">
              <h2 class="card-title"><i class="fa-solid fa-image"></i> Thumbnail</h2>
            </div>

            <div class="thumbnail-section">
              <% if (course.thumbnail) { %>
                <div class="thumbnail-preview">
                  <img src="<%= course.thumbnail %>" alt="Current thumbnail" />
                </div>
              <% } %>

              <div class="upload-area" id="upload-area">
                <input
                  type="file"
                  id="file-input"
                  name="thumbnail"
                  accept="image/*"
                  style="display:none"
                />

                <div class="upload-icon">
                  <i class="fa-solid fa-cloud-arrow-up"></i>
                </div>

                <div class="upload-text">Upload Thumbnail</div>
                <div class="upload-hint">PNG or JPG recommended</div>
              </div>
            </div>
          </section>

          <section class="edit-card sidebar-card">
            <div class="form-actions">
              <a href="/courses/<%= course._id %>" class="btn-secondary" target="_blank">
                <i class="fa-solid fa-eye"></i>
                Preview Course
              </a>

              <button type="submit" class="btn-primary">
                <i class="fa-solid fa-save"></i>
                Save Changes
              </button>
            </div>
          </section>

        </div>
      </div>
    </form>
  </div>
</main>
<!-- Uploading Progress Overlay -->
<div id="uploadProgressOverlay" class="modal-overlay hidden">
  <div class="modal-card">
    <div class="upload-progress-spinner">
      <i class="fa-solid fa-cloud-arrow-up fa-bounce" style="font-size: 3.5rem; color: var(--pink);"></i>
    </div>
    <h3 class="modal-title" style="margin-top: 15px;">Uploading Course Content...</h3>
    <p class="modal-text">Please do not close this tab. Uploading media files directly to Cloudinary.</p>
    
    <div class="progress-bar-container" style="background: rgba(255, 255, 255, 0.1); border-radius: 10px; height: 10px; width: 100%; overflow: hidden; margin-bottom: 15px; margin-top: 20px;">
      <div id="uploadProgressBar" style="background: linear-gradient(90deg, var(--pink), var(--teal)); width: 0%; height: 100%; transition: width 0.1s ease;"></div>
    </div>
    <span id="uploadProgressPercent" style="font-weight: 700; color: var(--text-white); font-size: 1.2rem;">0%</span>
  </div>
</div>

<!-- Success Popup Modal -->
<div id="successModal" class="modal-overlay hidden">
  <div class="modal-card">
    <div class="modal-icon">
      <i class="fa-solid fa-circle-check"></i>
    </div>
    <h3 class="modal-title">Changes Saved Successfully!</h3>
    <p class="modal-text">Your course has been updated with the latest changes.</p>
    <div class="modal-actions">
      <a href="/instructor/dashboard" class="modal-btn modal-btn-primary">
        <i class="fa-solid fa-chart-line"></i> Back to Dashboard
      </a>
      <button type="button" class="modal-btn modal-btn-secondary" onclick="closeSuccessModal()">
        Continue Editing
      </button>
    </div>
  </div>
</div>


<script src="/js/edit-course.js"></script>
</body>
</html>
