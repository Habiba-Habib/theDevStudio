<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Create New Course – Pricing</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/create-step3-css.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

</head>

<body>
<%- include('../partials/navbar') %>
<div class="page-wrapper">

  <h1 class="course-title">Create New Course</h1>
  <p class="course-description">Share your knowledge with students worldwide</p>

  <!-- STEPPER -->
  <div class="stepper">
  <div class="step active">
    <div class="step-circle">1</div>
    <div class="step-label">Basic Info</div>
  </div>
  <div class="step-line done"></div>
  <div class="step active">
    <div class="step-circle">2</div>
    <div class="step-label">Curriculum</div>
  </div>
  <div class="step-line done"></div>
  <div class="step active">
    <div class="step-circle">3</div>
    <div class="step-label">Pricing</div>
  </div>
</div>

  <!-- FORM (IMPORTANT) -->
<!-- DRAFT ACTIONS -->


<form action="/instructor/create/step3" method="POST" id="publish-form">

  <!-- Add this hidden input -->
  <% if (draft && draft._id) { %>
    <input type="hidden" name="courseId" value="<%= draft._id %>">
  <% } %>

    <div class="learn-box">

    <div class="free-toggle-wrapper">
      <label class="toggle-label">
        <input type="checkbox" id="free-toggle" name="isFree" <%= draft && draft.price == 0 ? 'checked' : '' %>>
        <span class="toggle-text">Make this course free</span>
      </label>
    </div>

    <div class="learn-grid">
      <div class="form-group">
        <label>Course Price ($) *</label>
<input type="number" class="form-input" name="price" id="price-input" 
       value="<%= draft && draft.price ? draft.price : '' %>" 
       placeholder="49.99" step="0.01" min="0" required>

        <div class="pricing-hint">Suggested: $29-99 for beginner courses</div>
      </div>

      <div class="form-group">
        <label>Course Duration *</label>
        <div style="display: flex; align-items: center; gap: 8px;">
<input type="number" class="form-input" name="duration" id="duration-input" 
       value="<%= draft && draft.duration ? draft.duration.toString().replace(/[^0-9.]/g, '') : '' %>" 
       placeholder="e.g., 10" min="0.5" step="0.5" required 
       style="width: 100%;" />

  <span style="color: #64748b;">hours</span>
</div>

      </div>
    </div>


      <!-- PREVIEW -->
  
<div class="preview-card-enhanced">
  <h3>Course Card Preview</h3>
  <p class="preview-subtitle">This is how your course will appear to students</p>
  
  <div class="course-card-preview">
    <div class="preview-image">
      <img id="preview-thumbnail" src="<%= draft && draft.thumbnail ? draft.thumbnail : '/images/course1.jpg' %>" alt="Course thumbnail">
      <span class="preview-badge" id="preview-level"><%= draft ? draft.level : 'Beginner' %></span>
    </div>
    
    <div class="preview-content">
      <h4 id="preview-title"><%= draft ? draft.title : 'Your Course Title' %></h4>
      <p id="preview-description"><%= draft ? draft.shortDescription : 'Your course description will appear here' %></p>
      
      <div class="preview-meta">
        <span><i class="fa-solid fa-book"></i> <span id="preview-sections"><%= draft && draft.sections ? draft.sections.length : 0 %></span> sections</span>
        <span><i class="fa-solid fa-clock"></i> <span id="preview-duration">0 hours</span></span>
        <span><i class="fa-solid fa-signal"></i> <span id="preview-level-text"><%= draft ? draft.level : 'Beginner' %></span></span>
      </div>
      
      <div class="preview-footer">
        <span class="preview-price-tag" id="preview-price">$0</span>
        <button type="button" class="preview-enroll-btn">Enroll Now</button>
      </div>
    </div>
  </div>
</div>


    </div>

    <!-- BUTTONS -->
 <div class="btn-row-three">
  <button type="button" class="btn-action btn-save-draft" onclick="saveDraft()">
    <i class="fa-solid fa-floppy-disk"></i> Save Draft
  </button>
  
  <button type="button" class="btn-action btn-delete-draft" onclick="deleteDraft()">
    <i class="fa-solid fa-trash"></i> Delete Draft
  </button>
  
<button type="submit" class="btn-action btn-publish-now" name="action" value="publish">
  <i class="fa-solid fa-rocket"></i> Publish Course
</button>


<div class="btn-row">
  <a href="/instructor/create/step2" class="btn-back">
    <i class="fa-solid fa-arrow-left"></i> Back
  </a>
</div>



  </form>

</div>

<script src="/js/create-step3-js.js"></script>

</body>
</html>