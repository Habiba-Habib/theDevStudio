<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Become an Instructor – EduPlatform</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/become-instructor.css"/>
  <link rel="stylesheet" href="/css/navbar-css.css">
</head>

<body>

<div class="page-wrapper">

  <!-- HEADER -->
  <div class="page-header">
    <div class="header-icon">
      <i class="fa-solid fa-graduation-cap"></i>
    </div>

    <h1>Become an Instructor</h1>
    <p>Complete your verification to start teaching on The Dev Studio</p>
  </div>

  <!-- STEP 1 -->
  <div class="form-section" id="section-1">

    <div class="form-card">
      <h2 class="card-title">Instructor Information</h2>

      <div class="form-row">
        <input class="form-input" id="full-name" placeholder="Full Name"/>
        <input class="form-input" id="job-title" placeholder="Job Title"/>
      </div>

      <div class="form-row">
        <input class="form-input" id="expertise" placeholder="Primary Expertise"/>
        <select class="form-input" id="experience">
          <option value="">Years of Experience</option>
          <option>1-2</option>
          <option>3-5</option>
          <option>5-10</option>
          <option>10+</option>
        </select>
      </div>

      <textarea class="form-input" id="bio" placeholder="Professional Bio"></textarea>
    </div>

    <div class="btn-row">
      <button class="btn-continue" id="btn-continue-1">Continue</button>
    </div>

  </div>

  <!-- STEP 2 -->
  <div class="form-section hidden" id="section-2">

    <div class="form-card">
      <h2 class="card-title">Upload Documents</h2>

      <input type="file" id="file-id"/>
      <input type="file" id="file-cert"/>
    </div>

    <div class="btn-row">
      <button class="btn-back" id="btn-back-2">Back</button>
      <button class="btn-continue" id="btn-continue-2">Continue</button>
    </div>

  </div>

  <!-- STEP 3 -->
  <div class="form-section hidden" id="section-3">

    <div class="form-card">
      <h2 class="card-title">Review</h2>
      <div id="review-grid"></div>
    </div>

    <div class="btn-row">
      <button class="btn-back" id="btn-back-3">Back</button>

      <!-- IMPORTANT: backend route -->
      <button class="btn-submit" id="btn-submit">
        Submit Application
      </button>
    </div>

  </div>

</div>

<!-- HELP -->
<button class="help-btn">?</button>

<!-- JS -->
<script src="/js/become-instructor.js"></script>
<script src="/js/main-navbar.js"></script>

</body>
</html>