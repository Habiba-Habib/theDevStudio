<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>Become an Instructor – EduPlatform</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/become-instructor.css"/>
  <link rel="stylesheet" href="/css/navbar-css.css">
</head>

<body>

<div class="page-wrapper">

  <!-- HEADER -->
  <div class="page-header">
    <div class="header-icon">
      <i class="fa-solid fa-graduation-cap"></i>
    </div>

    <h1>Become an Instructor</h1>
    <p>Complete your verification to start teaching on The Dev Studio</p>
  </div>

  <!-- STEP 1 -->
 <form class="form-section" id="section-1" action="/become-instructor" method="POST">

    <div class="form-card">
      <h2 class="card-title">Instructor Information</h2>

      <div class="form-row">
        <input class="form-input" id="full-name" name="fullName" placeholder="Full Name"/>
<input class="form-input" id="job-title" name="jobTitle" placeholder="Job Title"/>
<input class="form-input" id="expertise" name="expertise" placeholder="Primary Expertise"/>
<select class="form-input" id="experience" name="experience">
<textarea class="form-input" id="bio" name="bio" placeholder="Professional Bio"></textarea>
      </div>

      <div class="form-row">
        <input class="form-input" id="expertise" placeholder="Primary Expertise"/>
        <select class="form-input" id="experience">
          <option value="">Years of Experience</option>
          <option>1-2</option>
          <option>3-5</option>
          <option>5-10</option>
          <option>10+</option>
        </select>
      </div>

      <textarea class="form-input" id="bio" placeholder="Professional Bio"></textarea>
    </div>

    <div class="btn-row">
      <button class="btn-continue" id="btn-continue-1" type="submit">Continue</button>
    </div>

 </form>
 

<!-- HELP -->
<button class="help-btn">?</button>

<!-- JS -->
<script src="/js/become-instructor.js"></script>
<script src="/js/main-navbar.js"></script>

</body>
</html>