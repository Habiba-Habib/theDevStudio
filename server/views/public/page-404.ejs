<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>404 - Page Not Found</title>

  <link rel="stylesheet" href="/css/page-404.css" />

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
</head>

<body>
  <main class="error-page">
    <div class="bg-circle circle-one"></div>
    <div class="bg-circle circle-two"></div>

    <section class="error-card">
      <div class="badge">404 Error</div>

      <h1>Oops! Page Not Found</h1>

      <p>
        The page you are looking for does not exist, has been moved,
        or the link you entered is incorrect.
      </p>

      <div class="error-number">404</div>

      <div class="actions">
        <a href="/" class="btn primary-btn">Back to Home</a>
        <a href="/student/my-courses" class="btn secondary-btn">My Courses</a>
      </div>
    </section>
  </main>
</body>
</html>