<!DOCTYPE html>
<html lang="<%= locale || 'en' %>" dir="<%= isRTL ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TheDevStudio</title>
 <link rel="stylesheet" href="/css/home.css">
<link rel="stylesheet" href="/css/animations.css">
<link rel="stylesheet" href="/css/footer.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">  

</head>
<body>
<%- include('../partials/navbar') %>

    <main>
      <!--Hero Section-->
        <section class="hero"> 
            <div class="container">

             <span class="hero-tagline">
               <i class="fa-solid fa-rocket"></i>
                <%= __("home.heroTagline") %>
              </span>
      

               <h1 class="hero-title1"><%= __("home.heroTitle1") %></h1>
<h1 class="hero-title2"><%= __("home.heroTitle2") %></h1> 
<p><%= __("home.heroSubtitle") %></p>

            <div class="buttons">
               <button class="hero-buttn1">
                <a href="courses/all-courses">
                  <span class="browse-text"><%= __("home.browseCourses") %>
                   <i class="fa-solid fa-right-long"></i>                
                  </span>
                   </a> 
               </button>

               <button class="hero-buttn2">

                  <a href="/challenges">
                    <span class="btn-icon">
                         <i class="fa-solid fa-code"></i>
                    </span>
                       <%= __("home.startCoding") %>
                   </a>
                </button> 
              </div>
            </div> 
        </section>

        <!--To Be Modified-->
        <section class="cards-container">
            <div class="card-item">
                <span class="icon pink"><i class="fa-solid fa-users"></i></span>
                <div class="card-number"><%= stats.learners %></div>
                <div class="card-label"><%= __("home.activeLearners") %></div>
            </div>
            <div class="card-item">
                <span class="icon yellow"><i class="fa-solid fa-book"></i></span>
                <div class="card-number"><%= stats.courses %></div>
                <div class="card-label"><%= __("home.expertCourses") %></div>
            </div>
            <div class="card-item">
                <span class="icon green"><i class="fa-solid fa-trophy"></i></span>
                <div class="card-number"><%= stats.certified %></div>
                <div class="card-label"><%= __("home.certifiedStudents") %></div>
            </div>
            <div class="card-item">
                <span class="icon light-pink"><i class="fa-solid fa-bullseye"></i></span>
                <div class="card-number"><%= stats.successRate %></div>
                <div class="card-label"><%= __("home.successRate") %></div>
            </div>
        </section>
        
          
        <section class="featured-courses">
            <h1 class="section-title"><%= __("home.featuredCourses") %></h1>
            <p class="courses-tagline"><%= __("home.featuredCoursesTagline") %></p>

            <div class="courses-grid">
              <% courses.forEach(course => { %>
              <article class="courses-card">
                 <div class="courses-image">
                 <img src="<%= course.thumbnail %>" alt="courses">
                 <span class="badge"><%= course.level %></span>
                 </div>

           
                 <div class="content">
                <p class="category"><%= course.category %> • <%= course.duration %></p>
            <h3 class="card-title"><%= course.title %></h3>
            <p class="description"><%= course.shortDescription %></p>
            <p class="instructor">
              <%= __("home.byInstructor") %> <%= course.instructor?.name || __("home.defaultInstructor") %>
            </p>
            <div class="rating">
               <span class="card-rating">
              <i class="fa-solid fa-star"></i>
              <%= course.rating || 0 %>
               </span>
               <span class="card-students">
              <i class="fa-solid fa-users"></i>
               <%= course.students ? course.students.length : 0 %>
              </span>
            </div>

            <div class="card-footer">
                <span class="price">$<%= course.price %></span>
          <button class="btn-details">
            <a href="/courses/<%= course._id %>"><%= __("home.viewDetails") %></a>
          </button>
            </div>
            </div>
            </article>
            <% }) %>
            </div>
        </section>
       <div class="view-all-container">
          <a href="/courses/all-courses" class="view-all"><%= __("home.viewAllCourses") %> →</a>
        </div>

          

        <section class="challenges">
         <div class="challenges-content">
            <span class="challenge"><i class="fa-solid fa-trophy"></i> <%= __("home.challengeTagline") %></span>
            <h1 style="color:white; font-family: 'Inter' , sans-serif;"><%= __("home.challengeTitle") %></h1>
            <p style="color: #99A1AF; font-family: 'Inter' , sans-serif;"><%= __("home.challengeSubtitle") %></p>
            <button class="challenge-btn"><a href="/challenges"><%= __("home.exploreChallenges") %> 
                <span style="color:orange"><i class="fa-solid fa-bolt"></i></span>
            </a></button>
         </div>


         <div class="challenges-grid">
           <% if (challenges && challenges.length > 0) { %>
             <% challenges.forEach(challenge => { %>
               <a href="/challenges/<%= challenge._id %>" class="challenges-card-link">
                 <div class="challenges-card" data-difficulty="<%= challenge.difficulty %>">
                   <div class="challenge-card-top">
                     <span class="challenge-category-dot diff-<%= challenge.difficulty %>"></span>
                   </div>
                   <h3 class="challenge-title"><%= challenge.title %></h3>
                   <div class="challenge-footer">
                     <span class="difficulty <%= challenge.difficulty %>"><%= challenge.difficulty %></span>
                     <span class="points"><i class="fa-solid fa-bolt" style="color:#F0FE72;font-size:0.7rem;"></i> <%= challenge.points %> <%= __("home.points") %></span>
                   </div>
                 </div>
               </a>
             <% }) %>
           <% } else { %>
             <p style="color:var(--text-muted);grid-column:1/-1;text-align:center;padding:2rem 0;"><%= __("home.noChallenges") %></p>
           <% } %>
         </div>
         </section>

        <section class="why-DevStudio">
        <h1 class="section-title"><%= __("home.whyTitle") %></h1>
      <p class="courses-tagline"><%= __("home.whySubtitle") %></p>

  <div class="learning-grid">

    <div class="learning-card">
      <span class="learning-icon">
        <span class="icon pink"><i class="fa-solid fa-book"></i></span>
      </span>
      <h3 class="learning-title"><%= __("home.feature1Title") %></h3>
<p class="learning-desc"><%= __("home.feature1Desc") %></p>
    </div>

    <div class="learning-card">
      <span class="learning-icon">
        <span class="icon lightsalmon"><i class="fa-solid fa-code"></i></span>
      </span>
      <h3 class="learning-title"><%= __("home.feature2Title") %></h3>
<p class="learning-desc"><%= __("home.feature2Desc") %></p>
    </div>

    <div class="learning-card">
      <span class="learning-icon">
        <span class="icon green"><i class="fa-solid fa-trophy"></i></span>
      </span>
      <h3 class="learning-title"><%= __("home.feature3Title") %></h3>
<p class="learning-desc"><%= __("home.feature3Desc") %></p>
    </div>

    <div class="learning-card">
      <span class="learning-icon">
        <span class="icon yellow "><i class="fa-solid fa-bolt"></i></span>
      </span>
      <h3 class="learning-title"><%= __("home.feature4Title") %></h3>
<p class="learning-desc"><%= __("home.feature4Desc") %></p>
    </div>

    <div class="learning-card">
      <span class="learning-icon">
        <span class="icon purple"><i class="fa-solid fa-globe"></i></span>
      </span>
      <h3 class="learning-title"><%= __("home.feature5Title") %></h3>
<p class="learning-desc"><%= __("home.feature5Desc") %></p>
    </div>

   <div class="learning-card">
      <span class="learning-icon">
        <span class="icon light-pink"><i class="fa-solid fa-people-group"></i></span>
      </span>
      <h3 class="learning-title"><%= __("home.feature6Title") %></h3>
<p class="learning-desc"><%= __("home.feature6Desc") %></p>
    </div>


  </div>
  <div class="start-learning">
    <h1><%= __("home.readyTitle") %></h1>
    <p><%= __("home.readySubtitle") %></p>
    <button class="learning-btn">
      <a href="/auth/signup"> <%= __("home.getStarted") %> 
      <span class="arrow-icon">
         <i class="fa-solid fa-right-long"></i> 
      </span>
      </a>
     </button>
   
       
  </div>
</section>


    </main>
<%- include('../partials/footer') %>
    

  <script src="/js/animations.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
        const arrow = `<svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
        </svg>`;

        function typeWriter(element, text, speed = 80) {
            let i = 0;
            const interval = setInterval(() => {
                if (i < text.length) {
                    i++;
                    element.innerHTML = text.slice(0, i) + '<span class="cursor"></span>';
                } else {
                    clearInterval(interval);
                    element.innerHTML = text + arrow;
                }
            }, speed);
        }

        const browseText = document.querySelector('.browse-text');
        if (browseText) {
            typeWriter(browseText, '<%= __("home.browseCourses") %>');
        }
    });
</script>

</body>
</html>
 
