<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Administrator Access - TheDevStudio</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/admin-login.css" />
</head>
<body>
  <header class="admin-nav">
    <a href="/" class="brand">
      <span class="brand-icon"><i class="fa-solid fa-graduation-cap"></i></span>
      <span>TheDevStudio</span>
    </a>

    <nav class="nav-links">
      <a href="/courses/all-courses">Courses</a>
      <a href="/challenges">Challenges</a>
    </nav>

    <div class="nav-actions">
      <a href="/auth/login">Login</a>
      <a href="/auth/signup" class="signup-btn">Sign Up</a>
    </div>
  </header>

  <main class="admin-page">
    <section class="admin-info">
      <div class="portal-icon">
        <i class="fa-solid fa-shield-halved"></i>
      </div>

      <h1>Administrator<br><span>Access Portal</span></h1>
      <p class="lead">Secure access for platform administrators only.</p>

      <div class="restricted-card">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <div>
          <h2>Restricted Access</h2>
          <p>
            This area is reserved for authorized administrators only.
            All access attempts are logged and monitored.
            Unauthorized access is strictly prohibited.
          </p>
        </div>
      </div>

      <ul class="admin-list">
        <li><span>1</span>Manage platform users</li>
        <li><span>2</span>Review instructor applications</li>
        <li><span>3</span>Create coding challenges</li>
        <li><span>4</span>Monitor system activity</li>
      </ul>
    </section>

    <section class="admin-card">
      <div class="card-title-row">
        <i class="fa-solid fa-shield-halved"></i>
        <h2>Administrator Login</h2>
      </div>

      <p class="card-subtitle">Secure access for platform administrators</p>

      <form id="adminLoginForm" class="admin-form">
        <div class="form-group">
          <label for="adminEmail">Admin Email Address</label>
          <div class="input-box">
            <i class="fa-regular fa-envelope"></i>
            <input type="email" id="adminEmail" name="email" placeholder="admin@thedevstudio.com" required />
          </div>
        </div>

        <div class="form-group">
          <label for="adminPassword">Admin Password</label>
          <div class="input-box">
            <i class="fa-solid fa-lock"></i>
            <input type="password" id="adminPassword" name="password" placeholder="Enter your admin password" required />
            <button type="button" id="toggleAdminPassword" class="toggle-password">
              <i class="fa-regular fa-eye"></i>
            </button>
          </div>
        </div>

        <label class="remember-row">
          <input type="checkbox" name="rememberMe" />
          <span>Remember me</span>
        </label>

        <span id="adminLoginMessage" class="form-message"></span>

        <button type="submit" class="admin-submit">
          <i class="fa-solid fa-shield-halved"></i>
          Access Admin Panel
        </button>
      </form>

      <a href="/auth/login" class="back-link">← Back to Main Login</a>
    </section>
  </main>

  <script src="/js/admin-login.js"></script>
</body>
</html>