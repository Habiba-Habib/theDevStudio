<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TheDevStudio - Reset Password</title>
  <link rel="stylesheet" href="/css/forgot-password.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>

<%- include('../partials/navbar') %>

<main class="main-content">
  <div class="fp-grid">

    <div class="fp-left">
      <h1 class="fp-left-title">Create a New<br /><span class="fp-accent">Password</span></h1>
      <p class="fp-left-subtitle">Choose a secure password and get back to learning.</p>

      <ul class="fp-steps">
        <li class="fp-step"><span class="fp-step-num">1</span><span>Open your reset link</span></li>
        <li class="fp-step"><span class="fp-step-num">2</span><span>Enter a new password</span></li>
        <li class="fp-step"><span class="fp-step-num">3</span><span>Confirm your password</span></li>
        <li class="fp-step"><span class="fp-step-num">4</span><span>Log in again securely</span></li>
      </ul>
    </div>

    <div class="fp-right">
      <h2 class="fp-form-title">Reset Password</h2>
      <p class="fp-form-subtitle">Enter and confirm your new password</p>

      <% if (locals.successMessage) { %>
        <div id="fpSuccess" class="fp-success">
          <i class="fa-solid fa-circle-check"></i>
          <%= successMessage %>
        </div>

        <a href="/auth/login" class="fp-btn-send" style="display:block;text-align:center;text-decoration:none;">
          Back to Login
        </a>
      <% } else if (!token) { %>
        <div id="fpError" class="fp-error" style="display:block;">
          <%= errorMessage || "Reset link is invalid or expired." %>
        </div>

        <a href="/auth/forgot-password" class="fp-btn-send" style="display:block;text-align:center;text-decoration:none;">
          Request New Link
        </a>
      <% } else { %>

        <% if (locals.errorMessage) { %>
          <div id="fpError" class="fp-error" style="display:block;">
            <%= errorMessage %>
          </div>
        <% } %>

        <form action="/auth/reset-password/<%= token %>" method="POST">
          <div class="fp-form-group">
            <label class="fp-label" for="password">New Password</label>
            <div class="fp-input-wrapper">
              <i class="fa-solid fa-lock fp-input-icon"></i>
              <input
                type="password"
                id="password"
                name="password"
                class="fp-input"
                placeholder="Enter new password"
              />
            </div>
          </div>

          <div class="fp-form-group">
            <label class="fp-label" for="confirmPassword">Confirm Password</label>
            <div class="fp-input-wrapper">
              <i class="fa-solid fa-lock fp-input-icon"></i>
              <input
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                class="fp-input"
                placeholder="Confirm new password"
              />
            </div>
          </div>

          <button class="fp-btn-send" type="submit">Reset Password</button>
        </form>

      <% } %>
    </div>

  </div>
</main>

</body>
</html>