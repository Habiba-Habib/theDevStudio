<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <link rel="stylesheet" href="/css/profiles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
 
    
</head>

<body>
  <%- include('../partials/navbar') %>
    <h1 class="page-title">My Profile</h1>

  <main class="profile-container">

    <aside class="sidebar">
      <div class="avatar"><img src="/images/avatars/<%= user.avatar %>"></div>
      <h2><%= user.name %></h2>
      <p class="email"><%= user.email %></p>

      <div class="stat-card">
        <h3><%= user.points %></h3>
        <p>Total Points</p>
      </div>

      <div class="stat-card">
        <h3 style="color:#61b2b1">#<%= user.rank %></h3>
        <p>Global Rank</p>
      </div>

      <div class="stat-card">
        <h3 style="color:#ffb6e6"><%= user.badges %></h3>
        <p>Badges Earned</p>
      </div>
      <button type="submit" class="edit-btn" id="editProileBtn"> 
        <a href="/student/edit-profile">
          Edit Profile</a>
        </button>
    </aside>
    <div class="right-content">
    <section class="content">
      <h1>Personal Information</h1>

      <div class="profile-info">
        <div class="profile-grid">

          <div class="profile-group">
            <label>Full Name</label>
            <input type="text" id="name" value="<%= user.name %>" readonly>
          </div>

          <div class="profile-group">
            <label>Email</label>
            <input type="email" id="email" value="<%= user.email %>" readonly>
          </div>

          <div class="profile-group bio">
            <label>Bio</label>
            <textarea id="bio" readonly><%= user.bio %></textarea>
          </div>

          <div class="profile-group">
            <label>Location</label>
            <input type="text" id="location" value="<%= user.location %>" readonly>
          </div>

          <div class="profile-group">
                <label>Member Since</label>
                <input type="text" value="<%= user.memberSince %>" id="membersince" name="member_since" readonly>
           
          </div>

        </div>

        
    </div>
    </section>
    <section class="completed-courses">


        <h2 class="section-title">
        <i class="fa-solid fa-trophy"></i>
            Completed Courses
        </h2>


      <% completedCourses.forEach(course => { %>
      <div class="course-card">
      <span><%= course.title %></span>
      <button class="view-btn" onclick="goToCertificate()">View Certificate</button>
      </div>
      <% }) %>

    </section>


    <!-- SECTION 3 -->
    <section class="certificates">

  <h2 class="section-title">
   
  <i class="fa-solid fa-trophy"></i>

    Certificates
  </h2>

  <div class="certificate-grid">

    <% certificates.forEach(cert => { %>
  <div class="certificate-card">
    <div class="cert-icon"><i class="fa-solid fa-award"></i></div>
    <h3>Certificate of Completion</h3>
    <p>Issued: <%= cert.issuedDate %></p>
  </div>
<% }) %>

  </div>

</section>

  </div>
  </main>
  <script src="/js/student/profile.js"></script>

</body>
</html>
