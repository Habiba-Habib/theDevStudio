<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Challenge</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/create-challenge.css">
    <link rel="stylesheet" href="/css/navbar-css.css">
</head>
<body>

<%- include('../partials/navbar') %> 

    <div class="page-wrapper">

        <div class="page-header">
            <h1 class="page-title">Create Challenge</h1>
            <p class="page-subtitle">Create a new coding challenge manually or generate using AI</p>
        </div>

        <div class="ai-banner">
            <div class="ai-banner-left">
                <i class="fa-solid fa-wand-magic-sparkles ai-icon"></i>
                <div>
                    <p class="ai-banner-title">AI Challenge Generator</p>
                    <p class="ai-banner-desc">Generate a complete challenge with description, starter code, and test cases</p>
                </div>
            </div>
            <button class="btn-generate" id="generateBtn">
                <i class="fa-solid fa-wand-magic-sparkles"></i>
                Generate
            </button>
        </div>

        <div class="main-layout">

            <div class="form-card">

                <div class="form-group">
                    <label class="form-label">Challenge Title <span class="required">*</span></label>
                    <input type="text" id="challengeTitle" class="form-input"
                        placeholder="e.g., Two Sum Problem" autocomplete="off" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Difficulty <span class="required">*</span></label>
                        <div class="select-wrapper">
                            <select id="difficulty" class="form-select">
                                <option value="" disabled selected>Select difficulty</option>
                                <option value="Easy">Easy</option>
                                <option value="Medium">Medium</option>
                                <option value="Hard">Hard</option>
                            </select>
                            <i class="fa-solid fa-chevron-down select-arrow"></i>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Category <span class="required">*</span></label>
                        <div class="select-wrapper">
                            <select id="category" class="form-select">
                                <option value="" disabled selected>Select category</option>
                                <option value="Arrays">Arrays</option>
                                <option value="Strings">Strings</option>
                                <option value="Trees">Trees</option>
                                <option value="Graphs">Graphs</option>
                                <option value="Dynamic Programming">Dynamic Programming</option>
                                <option value="Sorting">Sorting</option>
                            </select>
                            <i class="fa-solid fa-chevron-down select-arrow"></i>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Description <span class="required">*</span></label>
                    <textarea id="description" class="form-textarea"
                        placeholder="Describe the challenge..."></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Starter Code</label>
                    <textarea id="starterCode" class="form-textarea code-textarea"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Test Cases <span class="required">*</span></label>
                    <textarea id="testCases" class="form-textarea code-textarea"></textarea>
                </div>

                <div class="form-actions">
                    <button class="btn-save" id="saveBtn">
                        <i class="fa-solid fa-floppy-disk"></i>
                        Save Challenge
                    </button>
                    <button class="btn-cancel" id="cancelBtn">Cancel</button>
                </div>

            </div>

            <div class="preview-card">
                <div class="preview-header">
                    <i class="fa-solid fa-eye preview-icon"></i>
                    <span class="preview-title">Preview</span>
                </div>
                <div class="preview-body" id="previewBody">
                    <div class="preview-empty">
                        <i class="fa-solid fa-code preview-empty-icon"></i>
                        <p>Fill in the form to see preview</p>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="/js/create-challenge.js"></script>
</body>
</html>