    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Manage Challenges</title>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
        <link rel="stylesheet" href="/css/manage-challenges.css">
    </head>
    <body>

    <%- include('../partials/navbar') %>

        <div class="page-wrapper">

            <div class="page-header">
                <div class="header-left">
                    <h1 class="page-title">Manage Challenges</h1>
                    <p class="page-subtitle">Create and manage coding challenges</p>
                </div>
                <button class="btn-create" onclick="window.location.href='/admin/create-challenge'">
                    <i class="fa-solid fa-plus"></i>
                    Create Challenge
                </button>
            </div>

            <div class="controls">
                <div class="search-wrapper">
                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                    <input type="text" id="searchInput" class="search-input" placeholder="Search challenges..." />
                </div>
                <div class="filter-tabs">
                    <button class="filter-tab active" data-filter="all">All</button>
                    <button class="filter-tab" data-filter="easy">Easy</button>
                    <button class="filter-tab" data-filter="medium">Medium</button>
                    <button class="filter-tab" data-filter="hard">Hard</button>
                </div>
            </div>

            <p class="results-count" id="resultsCount">
                Showing <%= challenges.length %> challenges
            </p>

            <div class="table-wrapper">
                <table class="challenges-table">
                    <thead>
                        <tr>
                            <th>Challenge</th>
                            <th>Category</th>
                            <th>Difficulty</th>
                            <th>Points</th>
                            <th>Submissions</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        <% challenges.forEach(c => { %>
                        <tr data-difficulty="<%= c.difficulty.toLowerCase() %>"
                            data-title="<%= c.title.toLowerCase() %>"
                            data-category="<%= c.category.toLowerCase() %>">
                            <td>
                                <div class="challenge-name"><%= c.title %></div>
                                <div class="challenge-desc"><%= c.desc %></div>
                            </td>
                            <td><span class="badge badge-category"><%= c.category %></span></td>
                            <td><span class="badge badge-<%= c.difficulty.toLowerCase() %>"><%= c.difficulty %></span></td>
                            <td><span class="points-value"><%= c.points %></span></td>
                            <td><%= (c.submissions || 0).toLocaleString() %></td>
                            <td>
                                <div class="action-btns">
                                    <button class="action-btn" title="View"
                                        onclick="window.location.href='/challenges/<%= c._id %>'">
                                        <i class="fa-regular fa-eye"></i>
                                    </button>
                                    <button class="action-btn" title="Edit"
                                        onclick="window.location.href='/admin/create-challenge?id=<%= c._id %>'">
                                        <i class="fa-regular fa-pen-to-square"></i>
                                    </button>
                                    <button class="action-btn delete" title="Delete"
                                        onclick="confirmDelete('<%= c._id %>')">
                                        <i class="fa-regular fa-trash-can"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <% if (recentlyDeleted.length > 0) { %>
            <div id="recentlyDeletedSection" style="margin-top: 40px;">
                <div class="page-header" style="margin-bottom: 16px;">
                    <div class="header-left">
                        <h2 style="color: var(--text-white); font-size: 18px; font-weight: 700;">
                            <i class="fa-solid fa-trash" style="color: var(--pink); margin-right: 8px;"></i>
                            Recently Deleted
                        </h2>
                        <p style="color: var(--text-muted); font-size: 13px;">
                            Restore or permanently remove deleted challenges
                        </p>
                    </div>
                </div>
                <div class="table-wrapper">
                    <table class="challenges-table">
                        <thead>
                            <tr>
                                <th>Challenge</th>
                                <th>Category</th>
                                <th>Difficulty</th>
                                <th>Points</th>
                                <th>Deleted</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="recentlyDeletedBody">
                            <% recentlyDeleted.forEach(c => { %>
                            <tr>
                                <td>
                                    <div class="challenge-name"><%= c.title %></div>
                                    <div class="challenge-desc"><%= c.desc %></div>
                                </td>
                                <td><span class="badge badge-category"><%= c.category %></span></td>
                                <td><span class="badge badge-<%= c.difficulty.toLowerCase() %>"><%= c.difficulty %></span></td>
                                <td><span class="points-value"><%= c.points %></span></td>
                                <td class="deleted-at" data-time="<%= c.deletedAt %>"></td>
                                <td>
                                    <div class="action-btns">
                                        <button class="action-btn restore-btn" title="Restore"
                                            onclick="restoreChallenge('<%= c._id %>')">
                                            <i class="fa-solid fa-rotate-left"></i>
                                        </button>
                                        <button class="action-btn delete" title="Permanently Delete"
                                            onclick="confirmPermanentDelete('<%= c._id %>')">
                                            <i class="fa-regular fa-trash-can"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            <% } %>

        </div>

        <div class="modal-overlay" id="modalOverlay">
            <div class="modal">
                <div class="modal-icon">
                    <i class="fa-solid fa-trash"></i>
                </div>
                <h3 class="modal-title">Delete Challenge</h3>
                <p class="modal-desc">Are you sure you want to delete this challenge? This action cannot be undone.</p>
                <div class="modal-actions">
                    <button class="modal-cancel" id="modalCancel">Cancel</button>
                    <button class="modal-confirm" id="modalConfirm">Delete</button>
                </div>
            </div>
        </div>

        <script src="/js/manage-challenges.js"></script>
    </body>
    </html>