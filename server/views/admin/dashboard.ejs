<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= admin.name %>'s Dashboard</title>
  <link rel="stylesheet" href="/css/dashboards.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

</head>
<body>
<%- include('../partials/navbar') %>
  <main class="main-content">

    <!-- Header -->
    <section class="ad-header">
      <h1 class="ad-title">Welcome, <%= admin.name %>!</h1>
      <p class="ad-subtitle"><%= admin.subtitle %></p>
    </section>

    <!-- Stat Cards -->
    <section class="stats-grid">

      <div class="stat-card">
        <div class="ad-card-top">
          <div class="stat-icon stat-icon--pink">
            <i class="fa-solid fa-users"></i>
          </div>
          <span class="ad-stat-change">↗ <%= stats.usersChange %></span>
        </div>
        <div class="stat-value"><%= stats.totalUsers.toLocaleString() %></div>
        <div class="stat-label">Total Users</div>
      </div>

      <div class="stat-card">
        <div class="ad-card-top">
          <div class="stat-icon stat-icon--yellow">
            <i class="fa-solid fa-book-open"></i>
          </div>
          <span class="ad-stat-change">↗ <%= stats.coursesChange %></span>
        </div>
        <div class="stat-value"><%= stats.totalCourses %></div>
        <div class="stat-label">Total Courses</div>
      </div>

      <div class="stat-card">
        <div class="ad-card-top">
          <div class="stat-icon stat-icon--teal">
            <i class="fa-solid fa-dollar-sign"></i>
          </div>
          <span class="ad-stat-change">↗ <%= stats.revenueChange %></span>
        </div>
        <div class="stat-value">$<%= stats.totalRevenue %></div>
        <div class="stat-label">Total Revenue</div>
      </div>

      <div class="stat-card">
        <div class="ad-card-top">
          <div class="stat-icon stat-icon--purple">
            <i class="fa-solid fa-code"></i>
          </div>
          <span class="ad-stat-change">↗ <%= stats.challengesChange %></span>
        </div>
        <div class="stat-value"><%= stats.totalChallenges %></div>
        <div class="stat-label">Total Challenges</div>
      </div>

    </section>

    <!-- Charts -->
    <div class="ad-charts-grid">

      <div class="ad-chart-card">
        <h2 class="section-title">User Growth</h2>
        <div class="ad-chart-wrapper">
          <canvas id="userGrowthChart"></canvas>
          <div class="ad-tooltip hidden" id="userTooltip"></div>
        </div>
      </div>

      <div class="ad-chart-card">
        <h2 class="section-title">Revenue Growth (K$)</h2>
        <div class="ad-chart-wrapper">
          <canvas id="revenueGrowthChart"></canvas>
          <div class="ad-tooltip hidden" id="revenueTooltip"></div>
        </div>
      </div>

    </div>

    <!-- Course Categories + Quick Actions -->
    <div class="ad-bottom-grid">

      <!-- Donut Chart -->
      <div class="ad-chart-card">
        <h2 class="section-title">Course Categories</h2>
        <div class="ad-donut-wrapper">
          <canvas id="donutChart"></canvas>
          <div class="ad-tooltip hidden" id="donutTooltip"></div>
        </div>
        <div class="ad-legend">
          <div class="ad-legend-item"><span class="ad-legend-dot ad-dot--webdev"></span> Web Dev</div>
          <div class="ad-legend-item"><span class="ad-legend-dot ad-dot--datascience"></span> Data Science</div>
          <div class="ad-legend-item"><span class="ad-legend-dot ad-dot--mobile"></span> Mobile</div>
          <div class="ad-legend-item"><span class="ad-legend-dot ad-dot--design"></span> Design</div>
          <div class="ad-legend-item"><span class="ad-legend-dot ad-dot--mlai"></span> ML/AI</div>
        </div>
      </div>

      <!-- Recent activi -->
      <div class="ad-chart-card ad-quick-actions-card">
        <h2 class="section-title">Quick Actions</h2>
        <div class="ad-actions-grid">

          <a href="#" class="ad-action-btn">
            <i class="fa-solid fa-arrow-trend-up ad-action-icon ad-icon--pink-light"></i>
            <span>View Analytics</span>
          </a>
          <a href="/admin/users" class="ad-action-btn">
          <i class="fa-solid fa-users ad-action-icon ad-icon--pink"></i>
          <span>Manage Users</span>
        </a>
        <a href="/courses/all-courses" class="ad-action-btn">
          <i class="fa-solid fa-book-open ad-action-icon ad-icon--yellow"></i>
          <span>Manage Courses</span>
        </a>
        <a href="/admin/manage-challenges" class="ad-action-btn">
          <i class="fa-solid fa-code ad-action-icon ad-icon--teal"></i>
          <span>Manage Challenges</span>
        </a>
        </div>
      </div>

    </div>

    <!-- Recent Activity -->
    <section class="ad-chart-card ad-activity-card">
      <h2 class="section-title">Recent Activity</h2>
      <% recentActivity.forEach(function(activity) { %>
      <div class="ad-activity-item">
        <img src="<%= activity.avatar %>"  class="ad-avatar" alt="avatar" />
        <div class="ad-activity-text">
          <p><strong><%= activity.userName %></strong>  <%= activity.action %> <span class="ad-activity-highlight ad-highlight--teal">Web Development Bootcamp</span></p>
          <span class="ad-activity-highlight ad-highlight--<%= activity.highlightColor %>"><%= activity.highlight %></span>
        </div>
      </div>
      <% }); %>
    </section>

    <button class="fp-help-btn">?</button>

  </main>

  <script src="/js/dashboards.js"></script>

</body>
</html>