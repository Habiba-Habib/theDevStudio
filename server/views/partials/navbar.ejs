<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
/>

<link rel="stylesheet" href="/css/navbar-css.css" />
<link rel="stylesheet" href="/css/chatbot.css" />

<script>
  window.devStudioI18n = {
    locale: "<%= locale || 'en' %>",
    courses: "<%= __('nav.courses') %>",
    challenges: "<%= __('nav.challenges') %>",
    login: "<%= __('nav.login') %>",
    signup: "<%= __('nav.signup') %>",
    dashboard: "<%= __('nav.dashboard') %>",
    logout: "<%= __('nav.logout') %>",
    profile: "<%= __('nav.profile') %>"
  };
</script>
<script defer src="/js/main-navbar.js"></script>

<button class="chatbot-toggle" id="chatbotToggle" type="button" aria-label="Open chat assistant">
  <i class="fa-solid fa-comments"></i>
  <span class="chatbot-notification"></span>
</button>

<section class="chatbot-window" id="chatbotWindow" aria-hidden="true">
  <div class="chatbot-header">
    <div class="chatbot-avatar-wrap">
      <div class="chatbot-avatar">
        <i class="fa-solid fa-headset"></i>
      </div>
      <span class="chatbot-online-dot"></span>
    </div>

    <div class="chatbot-title-block">
      <strong>Dev Studio Assistant</strong>
      <span><span class="status-dot"></span> Ready to Help</span>
    </div>

    <div class="chatbot-header-actions">
      <button id="chatbotMinimize" type="button" aria-label="Minimize chat">
        <i class="fa-solid fa-minus"></i>
      </button>
      <button id="chatbotClose" type="button" aria-label="Close chat">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
  </div>

  <div class="chatbot-messages" id="chatbotMessages">
    <div class="chatbot-row bot-row">
      <div class="bot-mini-avatar">
        <i class="fa-solid fa-headset"></i>
      </div>

      <div>
        <div class="chatbot-message bot">
          Welcome to The Dev Studio. How can I help you today?
        </div>
        <div class="chatbot-time">Just now</div>
      </div>
    </div>

    <div class="quick-actions" id="quickActions">
      <p>Quick Actions</p>

      <div class="quick-actions-grid">
        <button type="button" data-message="Help me find a course">
          <i class="fa-solid fa-book-open"></i>
          <span>Find a course</span>
        </button>

        <button type="button" data-message="Show me coding challenges">
          <i class="fa-solid fa-code"></i>
          <span>Browse challenges</span>
        </button>

        <button type="button" data-message="How can I track my progress?">
          <i class="fa-solid fa-chart-line"></i>
          <span>Track progress</span>
        </button>

        <button type="button" data-message="How do I contact support?">
          <i class="fa-solid fa-circle-question"></i>
          <span>Contact support</span>
        </button>

        <button type="button" data-message="How can I become an instructor?">
          <i class="fa-solid fa-chalkboard-user"></i>
          <span>Become instructor</span>
        </button>

        <button type="button" data-message="I need help with payment">
          <i class="fa-solid fa-credit-card"></i>
          <span>Payment help</span>
        </button>
      </div>
    </div>
  </div>

  <form class="chatbot-form" id="chatbotForm">
    <input
      id="chatbotInput"
      type="text"
      placeholder="Ask about courses, challenges, payments..."
      autocomplete="off"
    />
    <button type="submit" aria-label="Send message">
      <i class="fa-solid fa-paper-plane"></i>
    </button>
  </form>
</section>

<script defer src="/js/chatbot.js"></script>

<%- include('./cookie-consent') %>