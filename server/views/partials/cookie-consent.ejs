<link rel="stylesheet" href="/css/cookie-consent.css" />

<div class="cookie-banner hidden" id="cookieBanner" role="dialog" aria-label="Cookie consent">
  <div class="cookie-inner">
    <div class="cookie-left">
      <span class="cookie-emoji">🍪</span>
      <div class="cookie-text">
        <strong>We use cookies</strong>
        <p>We use cookies to improve your experience, analyse traffic and personalise content. By accepting you agree to our <a href="/auth/privacy-policy" class="cookie-link">Privacy Policy</a>.</p>
      </div>
    </div>
    <div class="cookie-actions">
      <button class="cookie-btn cookie-decline" id="cookieDecline">Decline</button>
      <button class="cookie-btn cookie-accept" id="cookieAccept">Accept All</button>
    </div>
  </div>
</div>

<script src="/js/cookie-consent.js"></script>
