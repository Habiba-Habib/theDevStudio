<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>EduPlatform | Complete Your Enrollment</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

  <link rel="stylesheet" href="/css/coursepayment.css"/>
  <link rel="stylesheet" href="/css/navbar-css.css">
</head>

<body>

  <main class="enroll-wrapper">

    <h1 class="enroll-title">Complete Your Enrollment</h1>

    <div class="enroll-grid">

      <!-- LEFT: Course Summary -->
      <aside class="enroll-card">
        <h2>Course Summary</h2>

        <img
          src="<%= course.image || 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&q=80' %>"
          alt="<%= course.title %>"
          class="course-img"
        />

        <h3 class="course-name"><%= course.title %></h3>

        <p class="course-author">
          By <%= course.instructorName || course.author || 'Instructor' %>
        </p>

        <p class="course-desc">
          <%= course.description %>
        </p>

        <div class="course-meta">
          <span class="course-rating">
            <i class="fa-solid fa-star"></i>
            <%= course.rating || '4.9' %>
          </span>
          <span class="dot">•</span>
          <span><%= course.duration || '12 hours' %></span>
        </div>

        <p class="course-price">
          $<%= Number(course.price || 0).toFixed(2) %>
        </p>

        <p class="course-access">One-time payment • Lifetime access</p>

        <hr class="divider"/>

        <div class="guarantee">
          <i class="fa-regular fa-circle-check"></i>
          30-day money-back guarantee
        </div>
      </aside>

      <!-- RIGHT: Payment Form -->
      <section class="enroll-card">

        <div class="payment-header">
          <div class="payment-icon">
            <i class="fa-solid fa-credit-card"></i>
          </div>
          <div>
            <h2>Payment Information</h2>
            <p class="payment-sub">All transactions are secure and encrypted</p>
          </div>
        </div>

       <form action="/student/payment/<%= course._id %>" method="POST">
        <input type="hidden" name="paymentMethod" value="card">

          <div class="field-group">
            <label for="cardName">Cardholder Name</label>
            <input type="text" placeholder="John Doe" id="cardName" name="cardName"/>
            <span class="field-error" id="err-cardName"></span>
          </div>

          <div class="field-group">
            <label for="cardNumber">Card Number</label>
            <div class="input-row">
              <input 
                type="text" 
                placeholder="1234 5678 9012 3456" 
                id="cardNumber" 
                name="cardNumber" 
                maxlength="19"
              />
              <div class="card-brands">
                <span class="brand visa">VISA</span>
                <span class="brand mc">MC</span>
              </div>
            </div>
            <span class="field-error" id="err-cardNumber"></span>
          </div>

          <div class="two-col">
            <div class="field-group">
              <label for="expiry">Expiry Date</label>
              <input type="text" placeholder="MM/YY" id="expiry" name="expiry" maxlength="5"/>
              <span class="field-error" id="err-expiry"></span>
            </div>

            <div class="field-group">
              <label for="cvv">CVV</label>
              <input type="text" placeholder="123" id="cvv" name="cvv" maxlength="3"/>
              <span class="field-error" id="err-cvv"></span>
            </div>
          </div>

          <div class="field-group">
            <label for="promo">Promo Code (Optional)</label>
            <input type="text" placeholder="Enter promo code" id="promo" name="promo"/>
            <span class="field-error" id="err-promo"></span>
          </div>

          <!-- Order Summary -->
          <div class="order-summary">
            <div class="order-row">
              <span>Subtotal</span>
              <span id="subtotal">$<%= Number(course.price || 0).toFixed(2) %></span>
            </div>

            <div class="order-row">
              <span>Tax</span>
              <span id="tax">$0.00</span>
            </div>

            <div class="order-row total-row">
              <span>Total</span>
              <span id="total" class="total-amount">
                $<%= Number(course.price || 0).toFixed(2) %>
              </span>
            </div>
          </div>

          <!-- Terms -->
          <div class="field-group">
            <label class="terms-label">
              <input type="checkbox" id="terms" name="terms"/>
              I agree to the terms and conditions and understand that this is a
              one-time payment for lifetime access to the course.
            </label>
            <span class="field-error" id="err-terms"></span>
          </div>

          <!-- Confirm Button -->
          <button class="btn-confirm" id="confirmBtn" type="submit">
            <i class="fa-solid fa-lock"></i>
            Confirm Payment
          </button>

        </form>

        <p class="secure-note">
          <i class="fa-solid fa-lock"></i>
          Your payment information is secure and encrypted
        </p>

        <a href="/student/my-courses" class="back-link">← Back to courses</a>

      </section>
    </div>
  </main>

  <script src="/js/coursepayment.js"></script>
  <script src="/js/main-navbar.js"></script>

</body>
</html>